struct pair =
    fst: 'a
    snd: 'b

let main = (args: str[]) ->
    let _result =
        // Allocate and initialize via pointer write
        let p = alloc(pair<int32, int64>)!
        p->fst = 42
        p->snd = 99i64
        let raw = (any*) p
        // Cast any* back to generic struct pointer
        let restored = (pair<int32, int64>*) raw
        let mut r = 0
        if restored->fst == 42 then r = r + 1
        if restored->snd == 99i64 then r = r + 1
        // Const cast variant
        let c = (const pair<int32, int64>*) raw
        if c->fst == 42 then r = r + 1
        free(raw)
        r
    assert(_result == 3)
    0
