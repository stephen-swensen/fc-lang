// Float-to-integer casts are total and saturating (audit item 16):
// in-range values truncate toward zero; out-of-range values clamp to the
// target type's min/max; nan converts to 0. A raw C cast would be undefined
// behavior at the range edges (and observably divergent across optimizers).
let main = (args: str[]) ->
    // --- in-range: truncates toward zero (not floor) ---
    assert((int32) 3.9 == 3)
    assert((int32) (-3.9) == -3)
    assert((int32) 0.0 == 0)
    assert((uint8) 200.7 == 200u8)
    assert((int64) (-7.99) == -7i64)

    // --- positive overflow clamps to max ---
    assert((int8) 1e30 == int8.max)
    assert((uint8) 1e30 == uint8.max)
    assert((int16) 1e30 == int16.max)
    assert((uint16) 1e30 == uint16.max)
    assert((int32) 1e30 == int32.max)
    assert((uint32) 1e30 == uint32.max)
    assert((int64) 1e30 == int64.max)
    assert((uint64) 1e30 == uint64.max)

    // --- negative overflow: clamps to min (signed) / 0 (unsigned) ---
    assert((int8) (-1e30) == int8.min)
    assert((int16) (-1e30) == int16.min)
    assert((int32) (-1e30) == int32.min)
    assert((int64) (-1e30) == int64.min)
    assert((uint8) (-1e30) == 0u8)
    assert((uint32) (-5.0) == 0u32)
    assert((uint64) (-1e30) == 0u64)

    // --- nan -> 0 (every width) ---
    assert((int32) float64.nan == 0)
    assert((uint8) float64.nan == 0u8)
    assert((int64) float64.nan == 0i64)

    // --- +/- infinity saturate like any out-of-range value ---
    assert((int32) float64.inf == int32.max)
    assert((int32) (-float64.inf) == int32.min)
    assert((uint32) (-float64.inf) == 0u32)

    // --- platform-width isize / usize (bounds via type properties) ---
    assert((isize) 1e30 == isize.max)
    assert((isize) (-1e30) == isize.min)
    assert((usize) 1e30 == usize.max)
    assert((usize) (-1.0) == 0u)
    assert((usize) 100.9 == 100u)
    assert((isize) (-100.9) == -100i)

    // --- float32 source: same bounds/truncation as float64 ---
    let f = 1e30f32
    assert((int32) f == int32.max)
    assert((int16) f == int16.max)
    let g = 42.9f32
    assert((uint8) g == 42u8)
    assert((int32) (-1.0f32 / 0.0f32) == int32.min)   // -inf (float32) clamps

    // --- interactions: cast result feeds widening, arithmetic, args ---
    let widened = (int32) 5.9 + 1i64                   // int32 -> int64 widen
    assert(widened == 6i64)
    let sum = (int32) 2.5e9 + (int32) (-2.5e9)         // max + min
    assert(sum == -1)                                  // int32.max + int32.min
    0
