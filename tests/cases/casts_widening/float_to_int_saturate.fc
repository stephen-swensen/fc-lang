// Float-to-integer casts are total and saturating (audit item 16):
// in-range values truncate toward zero; out-of-range values clamp to the
// target type's min/max; nan converts to 0. A raw C cast would be undefined
// behavior at the range edges (and observably divergent across optimizers).
let main = (args: str[]) ->
    // --- in-range: truncates toward zero (not floor) ---
    assert((i32) 3.9 == 3)
    assert((i32) (-3.9) == -3)
    assert((i32) 0.0 == 0)
    assert((u8) 200.7 == 200u8)
    assert((i64) (-7.99) == -7i64)

    // --- positive overflow clamps to max ---
    assert((i8) 1e30 == i8.max)
    assert((u8) 1e30 == u8.max)
    assert((i16) 1e30 == i16.max)
    assert((u16) 1e30 == u16.max)
    assert((i32) 1e30 == i32.max)
    assert((u32) 1e30 == u32.max)
    assert((i64) 1e30 == i64.max)
    assert((u64) 1e30 == u64.max)

    // --- negative overflow: clamps to min (signed) / 0 (unsigned) ---
    assert((i8) (-1e30) == i8.min)
    assert((i16) (-1e30) == i16.min)
    assert((i32) (-1e30) == i32.min)
    assert((i64) (-1e30) == i64.min)
    assert((u8) (-1e30) == 0u8)
    assert((u32) (-5.0) == 0u32)
    assert((u64) (-1e30) == 0u64)

    // --- nan -> 0 (every width) ---
    assert((i32) f64.nan == 0)
    assert((u8) f64.nan == 0u8)
    assert((i64) f64.nan == 0i64)

    // --- +/- infinity saturate like any out-of-range value ---
    assert((i32) f64.inf == i32.max)
    assert((i32) (-f64.inf) == i32.min)
    assert((u32) (-f64.inf) == 0u32)

    // --- platform-width isize / usize (bounds via type properties) ---
    assert((isize) 1e30 == isize.max)
    assert((isize) (-1e30) == isize.min)
    assert((usize) 1e30 == usize.max)
    assert((usize) (-1.0) == 0usize)
    assert((usize) 100.9 == 100usize)
    assert((isize) (-100.9) == -100isize)

    // --- f32 source: same bounds/truncation as f64 ---
    let f = 1e30f32
    assert((i32) f == i32.max)
    assert((i16) f == i16.max)
    let g = 42.9f32
    assert((u8) g == 42u8)
    assert((i32) (-1.0f32 / 0.0f32) == i32.min)   // -inf (f32) clamps

    // --- interactions: cast result feeds widening, arithmetic, args ---
    let widened = (i32) 5.9 + 1i64                   // i32 -> i64 widen
    assert(widened == 6i64)
    let sum = (i32) 2.5e9 + (i32) (-2.5e9)         // max + min
    assert(sum == -1)                                  // i32.max + i32.min
    0
