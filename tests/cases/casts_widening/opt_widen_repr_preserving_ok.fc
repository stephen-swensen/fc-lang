// Representation-preserving option widenings stay legal everywhere they were:
// adding const, and widening a typed pointer option to any*. None of these
// changes the value's bits, so the C cast is a no-op or a plain pointer cast.

// const-add on a pointer option (null-sentinel: bare pointer)
let p_const = (x: const i32*?) ->
    match x with
    | some(p) -> *p
    | none -> -1

// typed pointer option -> any* option (null-sentinel)
let p_any = (x: any*?) ->
    match x with
    | some(_) -> 1
    | none -> 0

// const-add on a slice option (struct option; const is display-only -> no-op cast)
let s_const = (x: const i32[]?) ->
    match x with
    | some(s) -> (i32) s.len
    | none -> -1

// const-add on a str option
let str_const = (x: const str?) ->
    match x with
    | some(s) -> (i32) s.len
    | none -> -1

struct holder =
    p: const i32*?

let main = (args: str[]) ->
    let mut n = 42

    // call-argument anchor positions
    let a = some(&n)                       // i32*?
    assert(p_const(a) == 42)               // i32*? -> const i32*?
    assert(p_any(a) == 1)                  // i32*? -> any*?

    let mut buf = i32[4] { }
    let sl = some(buf[0..4])               // i32[]?
    assert(s_const(sl) == 4)               // i32[]? -> const i32[]?

    let so = some("hello")                 // str?
    assert(str_const(so) == 5)             // str? -> const str?

    // struct-literal field position
    let h = holder { p = some(&n) }        // i32*? -> const i32*?
    assert(*(h.p!) == 42)

    // assignment position: q is inferred const i32*? from the const-cast seed,
    // then a plain i32*? widens into it on reassignment.
    let cp = (const i32*) &n             // const i32*
    let mut q = some(cp)                   // const i32*?
    q = some(&n)                           // i32*? -> const i32*?
    assert(*(q!) == 42)
    0
