// Explicit bool → numeric casts produce 0/1.
// Covers all integer widths (signed/unsigned), isize/usize, and both floats.
let main = (args: str[]) ->
    let t = true
    let f = false

    // Signed integers
    assert((i8) t == 1i8)
    assert((i8) f == 0i8)
    assert((i16) t == 1i16)
    assert((i32) t == 1)
    assert((i64) t == 1i64)
    assert((i32) f == 0)

    // Unsigned integers
    assert((u8) t == 1u8)
    assert((u16) t == 1u16)
    assert((u32) t == 1u32)
    assert((u64) t == 1u64)
    assert((u8) f == 0u8)

    // Platform-width
    assert((isize) t == 1isize)
    assert((usize) t == 1usize)
    assert((isize) f == 0isize)

    // Floats
    assert((f32) t == 1.0f32)
    assert((f64) t == 1.0)
    assert((f32) f == 0.0f32)
    assert((f64) f == 0.0)

    // Use in arithmetic — bit-packing flags
    let a = true
    let b = false
    let c = true
    let bits = ((i32) a) | ((i32) b << 1) | ((i32) c << 2)
    assert(bits == 0b101)

    // Sum of bool flags
    let count = (i32) a + (i32) b + (i32) c
    assert(count == 2)

    // In interpolation
    let has_key = true
    let s = "flag=%d{(i32) has_key}"
    assert(s.len == 6)
    assert(s[5] == 49u8)  // ASCII '1'

    0
