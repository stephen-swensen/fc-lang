struct point =
    x: i64
    y: i64

union holder =
    | val(i64)
    | empty

let main = (args: str[]) ->
    let _result =
        // struct field widening: i32 -> i64
        let p = point { x = 10, y = 20 }
        // variant payload widening: i32 -> i64
        let h = holder.val(42)
        let v = 
            match h with
            | val(n) -> (i32) n
            | empty -> 0
        // 10 + 20 + 42 = 72
        (i32) (p.x + p.y) + v
    assert(_result == 72)
    0
