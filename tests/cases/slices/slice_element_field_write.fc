// Field writes through bounds-checked slice indexing produce lvalues.
struct point =
    x: int32
    y: int32

let main = (args: str[]) ->
    let mut pts = alloc(point[3] { })!
    // Individual field writes on slice elements
    pts[0].x = 10
    pts[0].y = 20
    pts[1].x = 30
    pts[1].y = 40
    assert(pts[0].x == 10)
    assert(pts[0].y == 20)
    assert(pts[1].x == 30)
    assert(pts[1].y == 40)
    // Whole-element assignment still works
    pts[2] = point { x = 50, y = 60 }
    assert(pts[2].x == 50)
    free(pts)
    0
