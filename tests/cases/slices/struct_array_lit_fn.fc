// Test: passing struct array to function
struct point =
    x: i32
    y: i32

let sum_x = (pts: point[]) ->
    let mut total = 0
    for p in pts do
        total = total + p.x
    total

let main = (args: str[]) ->
    let arr = point[3] { point { x = 10, y = 0 }, point { x = 20, y = 0 }, point { x = 12, y = 0 } }
    assert(sum_x(arr) == 42)
    0
