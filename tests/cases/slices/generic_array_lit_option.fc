// generic element type combined with ? suffix: box<int32>?[N] { ... }
struct box =
    v: 'a

let main = (args: str[]) ->
    let b1 = box { v = 10 }
    let b3 = box { v = 5 }
    let arr = box<int32>?[3] { some(b1), default(box<int32>?), some(b3) }
    let mut sum = 0
    let mut nones = 0
    for o in arr
        match o with
        | some(v) -> sum = sum + v.v
        | none    -> nones = nones + 1
    assert(sum == 15)
    assert(nones == 1)
    0
