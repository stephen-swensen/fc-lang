// Test: equality on struct slices created from array literals.
// This test previously failed at default optimization due to VLA
// block-scope lifetime — the optimizer reused stack slots.
struct point =
    x: int32
    y: int32

let main = (args: str[]) ->
    let a = point[2] { point { x = 1, y = 2 }, point { x = 3, y = 4 } }
    let b = point[2] { point { x = 1, y = 2 }, point { x = 3, y = 4 } }
    let c = point[2] { point { x = 1, y = 2 }, point { x = 3, y = 5 } }
    if a == b then
        if a != c then 0
        else 2
    else 1
