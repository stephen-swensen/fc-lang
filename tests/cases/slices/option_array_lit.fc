// stack array literal of option-typed elements: int32?[N] { ... }
let main = (args: str[]) ->
    let opts = int32?[4] { some(10), default(int32?), some(3), some(9) }
    let mut sum = 0
    let mut nones = 0
    for o in opts
        match o with
        | some(v) -> sum = sum + v
        | none    -> nones = nones + 1
    assert(sum == 22)
    assert(nones == 1)
    0
