// stack slice literal of option-typed elements: i32?[N] { ... }
let main = (args: str[]) ->
    let opts = i32?[4] { some(10), none(i32), some(3), some(9) }
    let mut sum = 0
    let mut nones = 0
    for o in opts do
        match o with
        | some(v) -> sum = sum + v
        | none    -> nones = nones + 1
    assert(sum == 22)
    assert(nones == 1)
    0
