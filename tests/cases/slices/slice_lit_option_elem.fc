// slice-literal construction with an option element type: T?[] { ptr, len }
let main = (args: str[]) ->
    let mut buf = i32?[3] { some(1), none(i32), some(3) }
    let s = i32?[] { ptr = buf.ptr, len = 3i64 }
    assert(s.len == 3i64)
    let mut sum = 0
    for o in s do
        match o with
        | some(v) -> sum = sum + v
        | none    -> sum = sum + 100
    assert(sum == 104)
    0
