// Regression: a stack slice literal inside a loop must reuse a single backing
// slot hoisted to function entry, not __builtin_alloca a fresh frame extension
// every iteration. Pre-fix, alloca memory persisted until function return, so
// 100_000 iterations of a 512-int (2 KB) array grew the frame ~200 MB and
// segfaulted. With the fix the slot is reused, so this completes in bounded
// stack and the accumulated value is exact.
let main = (args: str[]) ->
    let mut acc = 0i64
    for i in 0..100000 do
        let buf = int32[512] { }
        buf[0] = i
        buf[511] = i
        acc = acc + (int64) (buf[0] + buf[511])
    // sum over i in [0, 100000) of (i + i) = 2 * (99999 * 100000 / 2)
    assert(acc == 9999900000i64)
    0
