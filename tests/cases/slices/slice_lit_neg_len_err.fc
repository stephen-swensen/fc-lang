// A statically-negative slice-literal length is rejected at compile time.
// A negative len defeats the unsigned-compare bounds-check fusion
// ((u64_t)idx >= (u64_t)len), so every later access would slip through.
let main = (args: str[]) ->
    let mut x = 42i32
    let p = &x
    let s = i32[] { ptr = p, len = -1 }
    s[0]
