// A closure in a for body may capture destructured loop bindings by copy;
// each iteration's bindings are independent.
let main = (args: str[]) ->
    let pairs = {int32, int32}[2] { { 1, 2 }, { 3, 4 } }
    let mut total = 0
    for { a, b } in pairs
        let f = () -> a + b
        total = total + f()
    assert(total == 10)
    0
