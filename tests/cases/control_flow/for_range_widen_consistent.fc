// The loop variable's type is the unified (widened) endpoint type, applied
// consistently to the C loop variable, the `<` test, and the `++`. A narrow
// start with a wider end must NOT clamp the loop variable to the narrow type
// (which previously overflowed: an i8 loop var can't represent 200).
let main = (args: str[]) ->
    let mut sum = 0i64
    for i in 0i8..200 do
        sum = sum + (i64) i
    assert(sum == 19900)

    // u8 start, i32 end: common type is i32, so i reaches 200.
    let mut count = 0i32
    for i in 0u8..200 do
        count = count + 1
    assert(count == 200)
    0
