let classify = (x: int32) ->
    if x < 0 then 1
    else if x == 0 then 2
    else if x < 10 then 3
    else if x < 100 then 4
    else 5

let main = (args: str[]) ->
    let a = classify(-5)
    let b = classify(0)
    let c = classify(7)
    let d = classify(42)
    let e = classify(200)
    assert(a + b + c + d + e == 15)
    0
