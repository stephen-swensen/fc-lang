// Regression: non-void last expression in for/if body with defer
// must not emit bare block-value statement that triggers -Werror=unused-value
let returns_int = () -> 42

let main = (args: str[]) ->
    // For-loop body: non-void last expr with defer in scope
    let mut sum = 0
    for i in 0..3
        let s = alloc("%d{i}")!
        defer free(s)
        sum = sum + i
        returns_int()
    assert(sum == 3)

    // If-then body: non-void last expr with defer in scope
    let mut val = 0
    if true then
        let s = alloc("hello")!
        defer free(s)
        val = 10
        returns_int()
    assert(val == 10)

    0
