// Block-form `for` requires `do` (uniform with `then`/`with`); `do` introduces
// the offside-indented body, exactly as in the inline form.
let main = (args: str[]) ->
    let xs = int32[4] { 1, 2, 3, 4 }
    let mut sum = 0
    for i, x in xs do
        if i > 0 then sum = sum + x
    assert(sum == 9)
    0
