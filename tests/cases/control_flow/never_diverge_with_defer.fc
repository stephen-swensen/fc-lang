// A value-producing arm with a `defer` coexists with a diverging sibling arm: the
// defer runs at arm-scope exit (after the value is captured), and the diverging
// arm emits as statements rather than an assignment.
let f = (o: int32?) ->
    let mut bonus = 0
    let v = match o with
    | some(w) ->
        defer bonus = 5
        w
    | none -> return -1
    v + bonus

let main = (args: str[]) ->
    assert(f(some(10)) == 15)          // v = 10, defer sets bonus = 5
    assert(f(none(int32)) == -1)   // diverging arm returns -1
    0
