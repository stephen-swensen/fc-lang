// Index + element destructuring: the index is a plain identifier, the element
// is destructured.
let main = (args: str[]) ->
    let pairs = {int32, int32}[3] { { 1, 2 }, { 3, 4 }, { 5, 6 } }
    let mut acc = 0i64
    for i, { a, b } in pairs
        acc = acc + i + (int64) (a + b)
    // (0+3) + (1+7) + (2+11) = 24
    assert(acc == 24)
    0
