// Index + element destructuring: the index is a plain identifier, the element
// is destructured.
let main = (args: str[]) ->
    let pairs = {i32, i32}[3] { { 1, 2 }, { 3, 4 }, { 5, 6 } }
    let mut acc = 0i64
    for i, { a, b } in pairs do
        acc = acc + i + (i64) (a + b)
    // (0+3) + (1+7) + (2+11) = 24
    assert(acc == 24)
    0
