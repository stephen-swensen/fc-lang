// Error: match arm producing a stack struct literal is rejected at return
struct holder =
    p: i32*

let bad = (u: i32?) ->
    let mut x = 42
    match u with
    | some(_) -> holder { p = &x }
    | none    -> holder { p = default(i32*) }

let main = (args: str[]) ->
    let _h = bad(some(1))
    0
