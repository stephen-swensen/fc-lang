// Storing stack addresses into a stack-allocated array of pointers is fine —
// the array does not outlive the frame.
let main = (args: str[]) ->
    let mut a = 1
    let mut b = 2
    let mut arr = int32*[2] { default(int32*), default(int32*) }
    arr[0] = &a
    arr[1] = &b
    assert(*arr[0] + *arr[1] == 3)
    0
