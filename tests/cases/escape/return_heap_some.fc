// Returning heap pointer wrapped in some is fine
let make = () ->
    let p = alloc(int32)!
    *p = 77
    some(p)

let main = (args: str[]) ->
    let _result =
        match make() with
        | some(p) ->
            let val = *p
            free(p)
            val
        | none -> 0
    assert(_result == 77)
    0
