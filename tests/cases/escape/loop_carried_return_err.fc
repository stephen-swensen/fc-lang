// A loop reads p before its stack reassignment textually, but iteration 2
// returns the stack pointer assigned in iteration 1. The loop pre-taint catches
// this despite the read appearing first in source order.
let bad = () ->
    let mut p = default(i32*)
    for i in 0..2 do
        if i > 0 then return p else void()
        let mut x = 5
        p = &x
    return default(i32*)

let main = (args: str[]) ->
    let r = bad()
    0
