// Reassigning a mut binding to a stack address must taint it for the heap sink
struct holder =
    p: int32*

let bad = (param: int32*) ->
    let h = alloc(holder { p = default(int32*) })!
    let mut p = param
    let mut x = 5
    p = &x
    h->p = p
    free(h)

let main = (args: str[]) ->
    bad(default(int32*))
    0
