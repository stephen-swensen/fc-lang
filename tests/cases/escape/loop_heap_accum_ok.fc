// A heap accumulator reassigned each iteration must NOT be over-tainted by the
// loop pre-taint — heap/unknown values never taint.
let pick = (n: i32) ->
    let mut best = alloc(i32)!
    *best = 0
    for i in 1..n do
        let cur = alloc(i32)!
        *cur = i
        free(best)
        best = cur
    return best

let main = (args: str[]) ->
    let r = pick(4)
    let v = *r
    free(r)
    assert(v == 3)
    0
