// Module-scoped import: wildcard import inside a module
module math =
    let add = (a: int32, b: int32) -> a + b
    let mul = (a: int32, b: int32) -> a * b

module wrapper =
    import * from math
    let compute = () -> add(mul(2, 3), mul(4, 5))

let main = (args: str[]) ->
    wrapper.compute()
