// Test: alloc and free with module-qualified struct type
module geometry =
    struct point =
        x: int32
        y: int32

let main = (args: str[]) ->
    let p = alloc(geometry.point)
    match p with
    | some(ptr) ->
        ptr->x = 10
        ptr->y = 20
        let sum = ptr->x + ptr->y
        free(ptr)
        sum
    | none -> 99
