module types =
    struct point =
        x: i32
        y: i32

module geometry =
    import point from types
    let origin = point { x = 0, y = 0 }
    let make = (x: i32, y: i32) -> point { x = x, y = y }

let main = (args: str[]) ->
    let p = geometry.make(3, 4)
    assert(p.x + p.y == 7)
    0
