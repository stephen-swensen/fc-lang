// Test: nested module-qualified struct type (two levels)
module outer =
    module inner =
        struct point =
            x: int32
            y: int32

let main = (args: str[]) ->
    let p = outer.inner.point { x = 3, y = 7 }
    let mut p2 = default(outer.inner.point)
    p2.x = 100
    let s = sizeof(outer.inner.point)
    if p.x + p.y == 10 then
        if p2.x == 100 then
            if s == 8 then 0
            else 3
        else 2
    else 1
