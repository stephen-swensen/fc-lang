namespace mylib::

module geom =
    let origin = () ->
        point { x = 0, y = 0 }

    let make = (x: int32, y: int32) ->
        point { x = x, y = y }

    let manhattan = (p: point) ->
        let ax = if p.x < 0 then 0 - p.x else p.x
        let ay = if p.y < 0 then 0 - p.y else p.y
        ax + ay
