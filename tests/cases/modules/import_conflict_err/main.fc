// Top-level let beats file-level import — same name is not a conflict,
// the let simply takes priority (members beat imports).
import add from math

let add = (a: int32, b: int32) -> a + b + 1

let main = (args: str[]) ->
    // Top-level let wins: a + b + 1
    let _result = add(1, 2)
    assert(_result == 4)
    0
