module m =
    struct point =
        x: i32
        y: i32

let main = (args: str[]) ->
    let _result =
        let a = m.point { x = 3, y = 4 }
        let b = m.point { x = 3, y = 4 }
        let c = m.point { x = 1, y = 2 }
        if a == b then
            if a != c then 42
            else 1
        else 2
    assert(_result == 42)
    0
