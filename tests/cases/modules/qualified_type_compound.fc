// Test: qualified type in pointer, slice, and option param positions
module m =
    struct point =
        x: int32
        y: int32

let use_ptr = (p: m.point*) -> p->x
let use_slice = (pts: m.point[]) -> pts[0].x
let use_option = (p: m.point?) ->
    match p with
    | some(v) -> v.x
    | none -> 0

let main = (args: str[]) ->
    let mut p = m.point { x = 42, y = 0 }
    let r1 = use_ptr(&p)
    let mut arr = alloc(m.point[2])!
    arr[0] = m.point { x = 99, y = 0 }
    let r2 = use_slice(arr)
    let r3 = use_option(some(m.point { x = 7, y = 0 }))
    free(arr.ptr)
    if r1 == 42 then
        if r2 == 99 then
            if r3 == 7 then 0
            else 3
        else 2
    else 1
