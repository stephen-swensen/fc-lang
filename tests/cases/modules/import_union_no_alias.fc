module shapes =
    union shape =
        | circle(int32)
        | rect(int32)

import shape from shapes

let area = (s: shape) ->
    match s with
    | circle(r) -> r * r
    | rect(w) -> w * w

let main = (args: str[]) ->
    let c = shape.circle(5)
    let r = shape.rect(4)
    area(c) + area(r)
