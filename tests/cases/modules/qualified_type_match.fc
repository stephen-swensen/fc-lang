// Test: pattern matching on module-qualified struct type
module geometry =
    struct point =
        x: i32
        y: i32

let main = (args: str[]) ->
    let _result =
        let p = geometry.point { x = 42, y = 58 }
        match p with
        | { x = a, y = b } -> a + b
    assert(_result == 100)
    0
