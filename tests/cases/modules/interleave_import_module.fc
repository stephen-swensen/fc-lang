// Child's imported module shadows a parent's module with the same name.
module impl_a =
    module util =
        let f = (x: int32) -> x + 1

module impl_b =
    module util =
        let f = (x: int32) -> x + 100

module parent =
    import util from impl_a

    module child =
        import util from impl_b
        let get = () -> util.f(0)

let main = (args: str[]) ->
    assert(parent.child.get() == 100)
    0
