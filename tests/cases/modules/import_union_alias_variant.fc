import color as col from shapes

module shapes =
    union color =
        | red
        | green
        | blue

let to_num = (c: col) ->
    match c with
    | red -> 1
    | green -> 2
    | blue -> 3

let main = (args: str[]) ->
    let r = col.red
    let g = col.green
    let b = col.blue
    assert(to_num(r) + to_num(g) + to_num(b) == 6)
    0
