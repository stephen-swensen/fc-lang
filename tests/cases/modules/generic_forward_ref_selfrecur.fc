// Forward-referenced generic function with self-recursion via module-qualified call.
module m =
    let sort = (s: int32[], cmp: (int32, int32) -> int32) ->
        m.sort_range(s, 0, s.len - 1, cmp)

    let sort_range = (s: 'a[], lo: int64, hi: int64, cmp: ('a, 'a) -> int32) ->
        if lo >= hi then return
        let mut i = lo
        for j in lo..hi
            if cmp(s[j], s[hi]) < 0 then
                let tmp = s[i]
                s[i] = s[j]
                s[j] = tmp
                i = i + 1
        let tmp = s[i]
        s[i] = s[hi]
        s[hi] = tmp
        m.sort_range(s, lo, i - 1, cmp)
        m.sort_range(s, i + 1, hi, cmp)

let main = (args: str[]) ->
    let mut data = alloc(int32[5] { })!
    data[0] = 5
    data[1] = 3
    data[2] = 1
    data[3] = 4
    data[4] = 2
    m.sort(data, (a: int32, b: int32) -> a - b)
    assert(data[0] == 1)
    assert(data[1] == 2)
    assert(data[2] == 3)
    assert(data[3] == 4)
    assert(data[4] == 5)
    free(data)
    0
