// import * from module should NOT re-export the module's internal imports.
// wrapper imports add from math; import * from wrapper should get compute but not add.
module math =
    let add = (a: int32, b: int32) -> a + b

module wrapper =
    import add from math
    let compute = () -> add(10, 20)

import * from wrapper

let main = (args: str[]) ->
    add(1, 2)
