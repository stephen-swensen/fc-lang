import shape from shapes
import shape_ops from shapes

module shapes =
    union shape =
        | circle(int32)
        | rect(int32)

    module shape_ops =
        let area_approx = (s: shape) ->
            match s with
            | circle(r) -> r * r * 3
            | rect(side) -> side * side

let main = (args: str[]) ->
    let c = shape.circle(1)
    assert(shape_ops.area_approx(c) == 3)
    0
