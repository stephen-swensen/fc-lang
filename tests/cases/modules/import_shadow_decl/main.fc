// Top-level let beats file-level import (members beat imports at every level).
// A local let inside main can still shadow the top-level let.
import add from math

let add = (a: i32, b: i32) -> a + b + 100

let main = (args: str[]) ->
    // Top-level let wins over file-level import
    assert(add(1, 2) == 103)
    // Local let shadows the top-level let
    let add = (a: i32, b: i32) -> a + b
    assert(add(1, 2) == 3)
    0
