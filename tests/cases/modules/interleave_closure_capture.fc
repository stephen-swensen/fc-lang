// Closure capture still works correctly after the scope_lookup_capture
// change: lambdas inside module functions can capture local variables
// across lambda boundaries within the current module scope.
module m =
    let apply_with = (n: int32, f: (int32) -> int32) ->
        let add = (x: int32) -> x + n
        f(add(0))

let main = (args: str[]) ->
    let result = m.apply_with(5, (x: int32) -> x * 2)
    assert(result == 10)
    0
