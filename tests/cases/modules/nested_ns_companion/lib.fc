namespace geo::

module types =
    struct vec2 =
        x: i32
        y: i32

module shapes =
    // Nested module imports struct from namespace sibling
    // and creates a companion module for it
    import vec2 from types

    struct rect =
        w: i32
        h: i32

    module rect =
        let square = (s: i32) -> rect { w = s, h = s }
        let area = (r: rect) -> r.w * r.h

    // Deeply nested module also imports from namespace sibling
    module tools =
        import vec2 from types
        let origin = () -> vec2 { x = 0, y = 0 }
