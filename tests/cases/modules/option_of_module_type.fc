module m =
    struct item =
        value: int32

let find = (x: int32) ->
    if x > 0 then some(m.item { value = x })
    else default(m.item?)

let main = (args: str[]) ->
    let _result =
        match find(42) with
        | some(it) -> it.value
        | none -> 0
    assert(_result == 42)
    0
