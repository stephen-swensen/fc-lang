struct point =
    x: int32
    y: int32

let mut origin = point { x = 0, y = 0 }

let main = (args: str[]) ->
    assert(origin.x == 0)
    assert(origin.y == 0)
    helper.shift(10, 20)
    assert(origin.x == 10)
    assert(origin.y == 20)
    helper.shift(5, 3)
    assert(origin.x == 15)
    assert(origin.y == 23)
    0
