import box from factory
import wrap from factory

module factory =
    struct box =
        value: 'a
    let wrap = (x: 'a) -> box { value = x }

let main = (args: str[]) ->
    let _result =
        let a = box { value = 99 }
        let b = wrap(99)
        if a == b then 42 else 1
    assert(_result == 42)
    0
