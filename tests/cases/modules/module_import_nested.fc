// Module-scoped imports are visible in nested child modules (lexical scoping)
module math =
    let add = (a: int32, b: int32) -> a + b
    let mul = (a: int32, b: int32) -> a * b

module outer =
    import math

    module middle =
        let use_math = () -> math.add(10, 20)

        module inner =
            let deep = () -> math.mul(3, 5)

let main = (args: str[]) ->
    outer.middle.use_math() + outer.middle.inner.deep()
