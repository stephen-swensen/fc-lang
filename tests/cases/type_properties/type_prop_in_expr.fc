// Test type properties used in expressions and function args
let add = (a: i32, b: i32) ->
    a + b

let clamp = (val: i32) ->
    if val > 100 then 100
    else if val < 0 then 0
    else val

let main = (args: str[]) ->
    // Use in function arguments
    let x = add(i32.max, i32.min)
    // INT32_MAX + INT32_MIN == -1 (wrapping arithmetic via unsigned cast)
    if x != -1 then return 1

    // Use in comparisons
    let y = 42
    if y > i32.max then return 2
    if y < i32.min then return 3

    // Use in arithmetic
    let z = u8.max - u8.min  // 255 - 0 = 255
    if (i32) z != 255 then return 4

    // Use in let binding and pass to function
    let limit = clamp(i32.bits)  // clamp(32) = 32
    if limit != 32 then return 5

    0
