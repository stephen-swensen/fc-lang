// Test static type properties: float min, max, epsilon, bits
let main = (args: str[]) ->
    // f64.min is the smallest positive normal value (> 0)
    if f64.min <= 0.0 then return 1
    // f64.max is a very large positive value
    if f64.max <= 0.0 then return 2
    // f64.epsilon > 0 and small
    if f64.epsilon <= 0.0 then return 3
    // 1.0 + epsilon != 1.0
    if 1.0 + f64.epsilon == 1.0 then return 4
    // f32 versions
    if f32.min <= 0.0f32 then return 5
    if f32.max <= 0.0f32 then return 6
    if f32.epsilon <= 0.0f32 then return 7
    // float bits
    if f32.bits != 32 then return 8
    if f64.bits != 64 then return 9
    // f64.max > f32.max (after cast)
    if f64.max <= (f64) f32.max then return 10
    0
