// Test static type properties: .bits on integer types
let main = (args: str[]) ->
    if i8.bits != 8 then return 1
    if i16.bits != 16 then return 2
    if i32.bits != 32 then return 3
    if i64.bits != 64 then return 4
    if u8.bits != 8 then return 5
    if u16.bits != 16 then return 6
    if u32.bits != 32 then return 7
    if u64.bits != 64 then return 8
    // .bits returns i32
    let b = i64.bits
    let c = b + 1
    if c != 65 then return 9
    0
