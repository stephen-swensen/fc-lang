// Test static type properties: integer min/max
let main = (args: str[]) ->
    // i8
    let a = i8.min
    let b = i8.max
    // i32
    let e = i32.min
    let f = i32.max
    // i64
    let g = i64.min
    let h = i64.max
    // u8
    let i = u8.min
    let j = u8.max
    // u32
    let m = u32.min
    // u64
    let o = u64.min

    // Verify known values
    let sum8 = (i32) a + (i32) b   // -128 + 127 = -1
    let check = (i32) j   // 255
    if (i32) i != 0 then return 1
    if check != 255 then return 2
    if sum8 != -1 then return 3
    if e >= 0 then return 4
    if f <= 0 then return 5
    if o != 0u64 then return 6
    if m != 0u32 then return 7
    if h <= (i64) f then return 8
    // i16 min/max
    if i16.min >= 0i16 then return 9
    if i16.max <= 0i16 then return 10
    // u16 min/max
    if u16.min != 0u16 then return 11
    if u16.max <= 0u16 then return 12
    // u32.max
    if u32.max <= 0u32 then return 13
    // u64.max
    if u64.max <= 0u64 then return 14
    // i64.min is negative
    if g >= 0i64 then return 15
    0
