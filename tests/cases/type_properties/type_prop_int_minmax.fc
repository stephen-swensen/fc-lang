// Test static type properties: integer min/max
let main = (args: str[]) ->
    // int8
    let a = int8.min
    let b = int8.max
    // int32
    let e = int32.min
    let f = int32.max
    // int64
    let g = int64.min
    let h = int64.max
    // uint8
    let i = uint8.min
    let j = uint8.max
    // uint32
    let m = uint32.min
    // uint64
    let o = uint64.min

    // Verify known values
    let sum8 = (int32) a + (int32) b   // -128 + 127 = -1
    let check = (int32) j   // 255
    if (int32) i != 0 then return 1
    if check != 255 then return 2
    if sum8 != -1 then return 3
    if e >= 0 then return 4
    if f <= 0 then return 5
    if o != 0u64 then return 6
    if m != 0u32 then return 7
    if h <= (int64) f then return 8
    // int16 min/max
    if int16.min >= 0i16 then return 9
    if int16.max <= 0i16 then return 10
    // uint16 min/max
    if uint16.min != 0u16 then return 11
    if uint16.max <= 0u16 then return 12
    // uint32.max
    if uint32.max <= 0u32 then return 13
    // uint64.max
    if uint64.max <= 0u64 then return 14
    // int64.min is negative
    if g >= 0i64 then return 15
    0
