// Static type properties are valid module-member initializers, including when
// nested inside other constant forms (struct/tuple literals, some(...), casts).
// Integer properties fold to literals; float and isize/usize properties are not
// host-foldable (target-defined / deferred to the C compiler) but still emit a
// valid C constant initializer (their stdint/float.h macro) directly.
struct range =
    lo: i32
    hi: i32

module m =
    // Integer (foldable).
    let imin = i32.min
    let imax = i64.max
    let ibits = u16.bits
    // Float (emitted as macro).
    let fmax = f64.max
    let fmin = f32.min
    let feps = f64.epsilon
    let fnan = f64.nan
    let finf = f32.inf
    let fninf = f64.neg_inf
    // isize / usize (target-defined; emitted as macro).
    let smin = isize.min
    let smax = isize.max
    let umax = usize.max
    let sbits = isize.bits
    // Nested in other constant forms.
    let r = range { lo = i32.min, hi = i32.max }
    let t = { i16.min, i16.max }
    let o = some(u8.max)
    let widened = (i64) i32.min

let main = (args: str[]) ->
    assert(m.imin == i32.min)
    assert(m.imax == i64.max)
    assert(m.ibits == 16)
    assert(m.fmax == f64.max)
    assert(m.fmin == f32.min)
    assert(m.feps == f64.epsilon)
    assert(m.fnan != m.fnan)            // NaN is never equal to itself
    assert(m.finf == f32.inf)
    assert(m.finf > f32.max)
    assert(m.fninf == f64.neg_inf)
    assert(m.smin == isize.min)
    assert(m.smax == isize.max)
    assert(m.umax == usize.max)
    assert(m.sbits == isize.bits)
    assert(m.r.lo == i32.min)
    assert(m.r.hi == i32.max)
    assert(m.t[0] == i16.min)
    assert(m.t[1] == i16.max)
    assert(m.o! == 255u8)
    assert(m.widened == (i64) i32.min)
    0
