// isize/usize +,-,* still compile at module scope: they emit plain C infix,
// which is a valid constant initializer (only div/mod stays blocked).
module m =
    let x = 20isize
    let sum = x + 1isize
    let prod = x * 2isize
    let u = 7usize
    let usum = u + 3usize

let main = (args: str[]) ->
    assert(m.sum == 21isize)
    assert(m.prod == 40isize)
    assert(m.usum == 10usize)
    0
