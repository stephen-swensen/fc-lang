// isize/usize +,-,* still compile at module scope: they emit plain C infix,
// which is a valid constant initializer (only div/mod stays blocked).
module m =
    let x = 20i
    let sum = x + 1i
    let prod = x * 2i
    let u = 7u
    let usum = u + 3u

let main = (args: str[]) ->
    assert(m.sum == 21i)
    assert(m.prod == 40i)
    assert(m.usum == 10u)
    0
