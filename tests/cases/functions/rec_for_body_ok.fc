// A self-call inside a `for` body is reached only if the loop runs at least once, so it
// is not on every path — the function can complete (e.g. when the range is empty) and is
// accepted. Called with an empty range so it terminates and the program exits 0.
let f = (n: i32) ->
    for i in 0..n do
        f(n)

let main = (args: str[]) ->
    f(0)
    0
