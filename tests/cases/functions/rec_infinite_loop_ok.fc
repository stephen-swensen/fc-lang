// An intentional infinite loop is written with `loop` and makes no self-call, so it is
// accepted (it compiles to `while (1)`, which the C compiler does not flag). Guarded so
// it is never entered at runtime; the point is that it compiles and the program exits 0.
let serve = (counter: int32*) ->
    loop
        counter[0] = counter[0] + 1

let main = (args: str[]) ->
    let mut n = 0
    if args.len > 99 then serve(&n)
    0
