// Chain of forward references: a -> b -> c, all defined bottom-up.
let a = (x: int32) -> b(x) + 1
let b = (x: int32) -> c(x) * 2
let c = (x: int32) -> x + 10

let main = (args: str[]) ->
    // c(3) = 13, b(3) = 26, a(3) = 27
    assert(a(3) == 27)
    assert(b(3) == 26)
    assert(c(3) == 13)
    0
