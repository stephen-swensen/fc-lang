// A void-returning recursive function whose tail is the recursive call, with the
// base case expressed as a bare `return`. The return type is void (derived from
// the bare return), not `never` — the function does terminate.
let count_down = (n: int32, acc: int32*) ->
    if n <= 0 then return
    acc[0] = acc[0] + n
    count_down(n - 1, acc)

let main = (args: str[]) ->
    let mut sum = 0
    count_down(5, &sum)
    assert(sum == 15)
    count_down(0, &sum)
    assert(sum == 15)
    0
