// A parenthesized type with more than one element (or a variadic) is only
// meaningful as a function parameter list and still requires the `->`. A grouped
// type is restricted to a single non-variadic element, so a bare multi-element
// `(i32, i32)` without an arrow is a parse error.
struct holder =
    x: (i32, i32)

let main = (args: str[]) ->
    0
