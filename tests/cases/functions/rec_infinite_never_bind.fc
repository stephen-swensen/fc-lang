// Bare infinite recursion has no base case — every path through `spin` recurses, so
// it never returns. FC rejects this at the function's definition (its generated C
// would otherwise trip the C compiler's -Winfinite-recursion). The error fires on the
// definition line, before the result is ever bound.
let main = (args: str[]) ->
    let spin = (n: i32) -> spin(n)
    let x = spin(3)
    assert(x == 0)
    0
