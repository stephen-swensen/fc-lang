// The base case is reachable only through nested control flow, and every
// top-level branch contains a recursive call. The anchor still finds the base
// case (the literal 1, nested two ifs deep) before a sibling consumes a
// recursive result.
let f = (n: int32) ->
    if n > 10 then n * f(n - 1)
    else
        if n > 1 then n * f(n - 1)
        else 1

let main = (args: str[]) ->
    assert(f(5) == 120)
    assert(f(12) == 479001600)
    0
