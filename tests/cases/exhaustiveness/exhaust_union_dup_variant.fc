// Duplicate variant arms should still be exhaustive if all variants covered
union color =
    | red
    | green
    | blue

let main = (args: str[]) ->
    let _result =
        let c = color.red
        match c with
        | red -> 1
        | green -> 2
        | blue -> 3
        | red -> 4
    assert(_result == 1)
    0
