// Struct with two union fields — requires cross-product reasoning
// 2 variants x 2 variants = 4 combinations, all covered
union bit =
    | zero
    | one

struct pair =
    a: bit
    b: bit

let decode = (p: pair) ->
    match p with
    | { a = zero, b = zero } -> 0
    | { a = zero, b = one } -> 1
    | { a = one, b = zero } -> 2
    | { a = one, b = one } -> 3

let main = (args: str[]) ->
    let p = pair { a = bit.one, b = bit.one }
    assert(decode(p) == 3)
    0
