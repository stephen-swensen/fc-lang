// Struct with two union fields — wildcard on one field covers remaining
union bit =
    | zero
    | one

struct pair =
    a: bit
    b: bit

let decode = (p: pair) ->
    match p with
    | { a = zero, b = zero } -> 0
    | { a = zero, b = one } -> 1
    | { a = one } -> 2

let main = (args: str[]) ->
    let p = pair { a = bit.one, b = bit.zero }
    decode(p)
