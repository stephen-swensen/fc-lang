// Struct with union field, exhaustive without wildcard
union shape =
    | circle(i32)
    | square(i32)
    | dot

struct drawing =
    x: i32
    shape: shape

let main = (args: str[]) ->
    let _result =
        let d = drawing { x = 5, shape = shape.circle(10) }
        match d with
        | { shape = circle(r) } -> r
        | { shape = square(s) } -> s
        | { shape = dot } -> 0
    assert(_result == 10)
    0
