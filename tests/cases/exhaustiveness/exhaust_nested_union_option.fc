// Union variant with option payload, all variants covered
union entry =
    | found(int32?)
    | missing

let check = (e: entry) ->
    match e with
    | found(some(v)) -> v
    | found(none) -> 0
    | missing -> -1

let main = (args: str[]) ->
    let r = check(entry.found(some(42)))
    assert(r + 1 == 43)
    0
