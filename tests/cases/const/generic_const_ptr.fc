// Generic function with const pointer param — tests const preservation
// through type resolution and monomorphization

let deref = (p: const 'a*) -> *p

let main = (args: str[]) ->
    let mut x = 42
    let mut y = 3.14f32
    let v1 = deref((const i32*) &x)
    let v2 = deref((const f32*) &y)
    v1 - 42
