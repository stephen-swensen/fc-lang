// x->y->z.a.b.c->e chain: mix of deref and value field access

struct e_node =
    val: int32

struct b_node =
    c: e_node*

struct a_node =
    b: b_node

struct z_node =
    a: a_node

struct y_node =
    z: z_node

struct x_node =
    y: y_node*

let main = (args: str[]) ->
    let mut e = e_node { val = 42 }
    let mut z = z_node { a = a_node { b = b_node { c = &e } } }
    let mut y = y_node { z = z }
    let mut x = x_node { y = &y }
    let xp = &x

    // non-const read through full chain
    let v1 = xp->y->z.a.b.c->val

    // non-const write through full chain
    xp->y->z.a.b.c->val = 99

    // read back after write
    let v2 = xp->y->z.a.b.c->val

    // const read through full chain
    let cxp = (const x_node*)xp
    let v3 = cxp->y->z.a.b.c->val

    // v1=42, v2=99, v3=99
    v1 + v2 + v3 - 240
