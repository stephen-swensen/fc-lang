let main = (args: str[]) ->
    let s1 = "hello"
    let s2 = alloc("hello")!
    let mut r = 0
    // const str == str (mixed constness)
    if s1 == s2 then r = r + 1 else r = r
    // str == const str (reversed)
    if s2 == s1 then r = r + 1 else r = r
    // const str == const str
    if s1 == "hello" then r = r + 1 else r = r
    free(s2)
    r - 3
