// bitwise NOT on platform-width integer types
let main = (args: str[]) ->
    let zu = 0usize
    let r1 = if ~zu == usize.max then 1 else 0
    let zi = 0isize
    let r2 = if ~zi == -1isize then 1 else 0
    let maxu = usize.max
    let r3 = if ~maxu == 0usize then 1 else 0
    assert(r1 + r2 + r3 == 3)
    0
