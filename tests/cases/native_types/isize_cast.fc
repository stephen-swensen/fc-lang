let main = (args: str[]) ->
    // cast from fixed to isize/usize
    let a = (isize) 42
    let b = (usize) 42
    // cast from isize/usize to fixed
    let c = (i32) a
    let d = (i64) a
    let e = (u64) b
    let f = (i32) b
    // cast between isize and usize
    let g = (usize) a
    let h = (isize) b
    // cast from/to float requires going through int
    let i = (i32) a
    let j = (f64) i
    assert(c + f == 84)
    0
