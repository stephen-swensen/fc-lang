let main = (args: str[]) ->
    let a = 42usize
    let b = 10usize
    let sum = a + b
    assert((i32) (sum) == 52)
    let diff = a - b
    assert((i32) (diff) == 32)
    let prod = a * b
    assert((i32) (prod) == 420)
    let zero = 0usize
    assert((i32) (zero) == 0)
    assert((i32) (sum + diff + prod + zero) == 504)
    0
