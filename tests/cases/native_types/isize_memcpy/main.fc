module c from "string.h" =
    extern memcpy: (any*, const any*, usize) -> any*
    extern strlen: (const cstr) -> usize

module libc from "stdlib.h" =
    extern malloc: (usize) -> any*

let main = (args: str[]) ->
    // allocate with usize — matches C's malloc(size_t)
    let size = 6usize
    let buf = libc.malloc(size)

    // memcpy with usize length
    let src = c"hello"
    let len = c.strlen(src)
    c.memcpy(buf, src, len + 1usize)

    // verify the copy worked
    let result = (cstr) buf
    let rlen = c.strlen(result)
    free((i32*) buf)
    assert((i32) rlen == 5)
    0
