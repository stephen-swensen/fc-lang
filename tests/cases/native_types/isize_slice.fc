let main = (args: str[]) ->
    let mut a = alloc(isize[3] { })!
    a[0] = 10isize
    a[1] = 20isize
    a[2] = 30isize
    let mut b = alloc(usize[2] { })!
    b[0] = 5usize
    b[1] = 7usize
    let r1 = (i32) a[0] + (i32) a[1] + (i32) a[2]
    let r2 = (i32) b[0] + (i32) b[1]
    free(a)
    free(b)
    assert(r1 + r2 == 72)
    0
