let main = (args: str[]) ->
    let a = 0xFFi
    let b = 0x0Fi
    let r1 = (int32)(a & b)
    let r2 = (int32)(a | b)
    let r3 = (int32)(a ^ b)
    let r4 = (int32)(1i << 4i)
    let r5 = (int32)(32i >> 2i)
    // usize bitwise
    let c = 0xFFu
    let d = 0x0Fu
    let r6 = (int32)(c & d)
    let r7 = (int32)(1u << 4u)
    r1 + r4 + r5 + r6 + r7
