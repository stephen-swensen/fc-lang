module c from "string.h" =
    extern strlen: (cstr) -> usize
    extern memcmp: (any*, any*, usize) -> int32

let main = (args: str[]) ->
    // strlen returns usize — matches C's size_t
    let s = c"hello"
    let len = c.strlen(s)

    // use usize for length comparisons
    let r1 = if len == 5u then 1 else 0

    // pass usize to C function expecting size_t
    let s2 = c"hello"
    let cmp = c.memcmp((any*)s, (any*)s2, len)
    let r2 = if cmp == 0 then 1 else 0

    // cast usize to int32 for return
    let r3 = (int32)len

    r1 + r2 + r3
