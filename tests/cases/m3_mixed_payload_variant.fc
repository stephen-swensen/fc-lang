union shape =
    | circle(int32)
    | square(int32)
    | point

let main = (args: int32) ->
    let s = shape.circle(5)
    let r1 = match s with
    | circle(r) -> r
    | square(w) -> w
    | point -> 0
    let s2 = default(shape)
    let r2 = match s2 with
    | circle(r) -> r + 100
    | square(_) -> 200
    | point -> 99
    r1 + r2
