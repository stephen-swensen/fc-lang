struct maybe_val =
    tag: int32
    val: 'a?

let main = (args: str[]) ->
    let a = maybe_val { tag = 1, val = some(42) }
    let b = maybe_val { tag = 1, val = some(42) }
    let c = maybe_val { tag = 1, val = default(int32?) }
    let mut r = 0
    if a == b then r = r + 1 else r = r
    if a != c then r = r + 2 else r = r
    r
