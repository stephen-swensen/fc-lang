union token =
    | number(int32)
    | name(int32)
    | eof

let main = (args: str[]) ->
    let _result =
        let a = token.number(42)
        let b = token.number(42)
        let c = token.number(99)
        let d = token.eof
        let e = token.eof
        let f = token.name(1)
        let mut r = 0
        if a == b then r = r + 1
        if a != c then r = r + 2
        if d == e then r = r + 4
        if a != d then r = r + 8
        if a != f then r = r + 16
        r
    assert(_result == 31)
    0
