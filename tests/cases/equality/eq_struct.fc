struct point =
    x: int32
    y: int32

let main = (args: str[]) ->
    let _result =
        let a = point { x = 1, y = 2 }
        let b = point { x = 1, y = 2 }
        let c = point { x = 3, y = 4 }
        let mut r = 0
        if a == b then r = r + 1
        if a != c then r = r + 2
        if a == c then r = r + 10
        if a != b then r = r + 10
        if b != c then r = r + 4
        r
    assert(_result == 7)
    0
