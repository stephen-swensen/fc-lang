struct pair =
    first: 'a
    second: 'b

let main = (args: str[]) ->
    let _result =
        let a = pair { first = 1, second = true }
        let b = pair { first = 1, second = true }
        let c = pair { first = 1, second = false }
        let d = pair { first = "hello", second = "world" }
        let e = pair { first = "hello", second = "world" }
        let f = pair { first = "hello", second = "other" }
        let mut r = 0
        if a == b then r = r + 1
        if a != c then r = r + 2
        if d == e then r = r + 4
        if d != f then r = r + 8
        r
    assert(_result == 15)
    0
