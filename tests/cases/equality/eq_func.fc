let add_one = (x: int32) -> x + 1
let add_two = (x: int32) -> x + 2

let main = (args: str[]) ->
    let _result =
        let f = add_one
        let g = add_one
        let h = add_two
        let mut r = 0
        if f == g then r = r + 1
        if f != h then r = r + 2
        r
    assert(_result == 3)
    0
