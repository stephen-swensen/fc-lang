union shape =
    | circle(int32)
    | square(int32)

let main = (args: str[]) ->
    let _result =
        let a = shape.circle(5)
        let b = shape.circle(5)
        let c = shape.square(5)
        let d = shape.circle(3)
        let mut r = 0
        if a == b then r = r + 1
        if a != c then r = r + 2
        if a != d then r = r + 4
        r
    assert(_result == 7)
    0
