struct point =
    x: int32
    y: int32

let main = (args: str[]) ->
    let _result =
        let a = alloc(point[2] { })!
        a[0] = point { x = 1, y = 2 }
        a[1] = point { x = 3, y = 4 }
        let b = alloc(point[2] { })!
        b[0] = point { x = 1, y = 2 }
        b[1] = point { x = 3, y = 4 }
        let c = alloc(point[2] { })!
        c[0] = point { x = 1, y = 2 }
        c[1] = point { x = 9, y = 9 }
        let mut r = 0
        if a == b then r = r + 1
        if a != c then r = r + 2
        free(a)
        free(b)
        free(c)
        r
    assert(_result == 3)
    0
