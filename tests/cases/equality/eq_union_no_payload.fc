union color =
    | red
    | green
    | blue

let main = (args: str[]) ->
    let _result =
        let a = color.red
        let b = color.red
        let c = color.blue
        let mut r = 0
        if a == b then r = r + 1
        if a != c then r = r + 2
        r
    assert(_result == 3)
    0
