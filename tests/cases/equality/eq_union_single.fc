union wrapper =
    | val(int32)

let main = (args: str[]) ->
    let _result =
        let a = wrapper.val(42)
        let b = wrapper.val(42)
        let c = wrapper.val(99)
        let mut r = 0
        if a == b then r = r + 1
        if a != c then r = r + 2
        r
    assert(_result == 3)
    0
