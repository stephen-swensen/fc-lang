struct pair =
    first: 'a
    second: 'b

let main = (args: str[]) ->
    let a = pair { first = 1, second = 2 }
    let b = pair { first = 1, second = 2 }
    let c = pair { first = 1, second = 9 }
    let mut r = 0
    if a == b then r = r + 1 else r = r
    if a != c then r = r + 2 else r = r
    r
