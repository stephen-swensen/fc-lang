// A capturing lambda produced as the tail of an `if`/`else` arm, then copied out
// into a binding. Each arm builds its own context struct in a nested
// statement-expression; both must get function-frame lifetime. Exercises both
// arms (the taken one carries the live capture).
let apply = (f: (int32) -> int32, x: int32) ->
    f(x)

let main = (args: str[]) ->
    let base = 100
    let pick =
        if base > 50 then
            let hi = base
            (x: int32) -> x + hi
        else
            let lo = base
            (x: int32) -> x - lo
    assert(apply(pick, 5) == 105)
    0
