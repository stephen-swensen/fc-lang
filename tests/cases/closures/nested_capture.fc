let apply = (f: (i32) -> i32, x: i32) -> f(x)
let apply2 = (f: (i32) -> i32, x: i32) -> f(x)

let main = (args: str[]) ->
    let _result =
        let a = 10
        let outer = (x: i32) ->
            let b = 20
            let inner = (y: i32) -> y + a + b
            apply2(inner, x)
        apply(outer, 12)
    assert(_result == 42)
    0
