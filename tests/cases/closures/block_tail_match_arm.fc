// A capturing lambda produced as the tail of a `match` arm, then copied out into
// a binding. The arm body is a block whose tail expression is the closure; its
// context must outlive the arm's statement-expression to function scope.
union op =
    | inc
    | dec

let apply = (f: (i32) -> i32, x: i32) ->
    f(x)

let main = (args: str[]) ->
    let base = 100
    let k = op.inc
    let f =
        match k with
        | inc ->
            let amt = base
            (x: i32) -> x + amt
        | dec ->
            let amt = base
            (x: i32) -> x - amt
    assert(apply(f, 5) == 105)
    0
