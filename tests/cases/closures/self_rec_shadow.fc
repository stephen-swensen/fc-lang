// Shadowing: a `let f = <lambda>` binding is visible inside its own body, so the
// inner `f` is self-recursive and does NOT refer to the outer `f`.
let main = (args: str[]) ->
    let f = (x: int32) -> x + 1          // outer f: increment
    let f = (x: int32) ->                // inner f shadows; self-recursive
        if x <= 0 then 0
        else f(x - 1) + 2                // calls itself, not the outer f
    // self-recursive: f(3) = f(2)+2 = f(1)+2+2 = f(0)+2+2+2 = 0+6 = 6
    // (if it referred to the outer f, the result would be outer(2)+2 = 5)
    assert(f(3) == 6)
    0
