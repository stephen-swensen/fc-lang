// Block-tail inside block-tail: the lambda sits two statement-expression levels
// deep (a let…in whose tail is an `if` whose then-arm tail is the closure). The
// hoisted backing is at function scope regardless of nesting depth, so the
// "where to hoist" question has a single answer no matter how deep the tail is.
let apply = (f: (i32) -> i32, x: i32) ->
    f(x)

let main = (args: str[]) ->
    let base = 10
    let g =
        let a = base
        if a > 0 then
            let b = a + 5
            (x: i32) -> x + b
        else
            (x: i32) -> x
    assert(apply(g, 100) == 115)
    0
