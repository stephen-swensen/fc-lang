// Struct destructure with nested union match via wildcard
struct container =
    label: int32
    value: int32

union wrapped =
    | boxed(container)
    | empty

let check = (w: wrapped) ->
    match w with
    | boxed({ label = l, value = v }) -> l + v
    | empty -> 0

let main = (args: str[]) ->
    check(wrapped.boxed(container { label = 10, value = 20 }))
