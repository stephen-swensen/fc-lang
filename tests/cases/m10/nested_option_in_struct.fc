struct wrapper =
    val: int32??

let check = (w: wrapper) ->
    match w.val with
    | some(some(v)) -> v
    | some(none) -> 0
    | none -> -1

let main = (args: str[]) ->
    let a = wrapper { val = some(some(10)) }
    let b = wrapper { val = some(none(int32)) }
    let c = wrapper { val = none(int32?) }
    check(a) + check(b) + check(c)
