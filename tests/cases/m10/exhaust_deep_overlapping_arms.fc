// Overlapping but collectively exhaustive arms
// No single arm covers a full variant — coverage comes from combinations
union shape =
    | circle(int32)
    | square(int32)

struct styled =
    shape: shape
    bold: bool

let score = (s: styled) ->
    match s with
    | { shape = circle(r), bold = true } -> r + 100
    | { shape = square(s), bold = true } -> s + 200
    | { bold = false } -> 0

let main = (args: str[]) ->
    let s1 = styled { shape = shape.circle(5), bold = true }
    let s2 = styled { shape = shape.square(3), bold = false }
    score(s1) + score(s2)
