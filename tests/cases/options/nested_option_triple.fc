let check = (x: i32???) ->
    match x with
    | some(some(some(v))) -> v
    | some(some(none)) -> 10
    | some(none) -> 20
    | none -> 30

let main = (args: str[]) ->
    let a = some(some(some(5)))
    let b = some(some(none(i32)))
    let c = some(none(i32?))
    let d = none(i32??)
    assert(check(a) + check(b) + check(c) + check(d) == 65)
    0
