let check = (x: int32???) ->
    match x with
    | some(some(some(v))) -> v
    | some(some(none)) -> 10
    | some(none) -> 20
    | none -> 30

let main = (args: str[]) ->
    let a = some(some(some(5)))
    let b = some(some(default(int32?)))
    let c = some(default(int32??))
    let d = default(int32???)
    assert(check(a) + check(b) + check(c) + check(d) == 65)
    0
