let main = (args: str[]) ->
    // pointer options use null-sentinel representation
    let mut v = 10
    let x = some(&v)
    let y = default(int32*?)
    assert(x.is_some)
    assert(!x.is_none)
    assert(y.is_none)
    assert(!y.is_some)

    // unwrap after is_some check
    if x.is_some then
        assert(*x! == 10)

    0
