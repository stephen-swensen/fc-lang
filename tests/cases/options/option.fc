let find_first_positive = (a: int32, b: int32, c: int32) ->
    if a > 0 then some(a)
    else if b > 0 then some(b)
    else if c > 0 then some(c)
    else default(int32?)

let main = (args: str[]) ->
    let _result =
        let result = find_first_positive(-1, 42, 99)
        match result with
        | some(v) -> v
        | none -> 0
    assert(_result == 42)
    0
