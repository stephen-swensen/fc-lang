let find_first_positive = (a: i32, b: i32, c: i32) ->
    if a > 0 then some(a)
    else if b > 0 then some(b)
    else if c > 0 then some(c)
    else none(i32)

let main = (args: str[]) ->
    let _result =
        let result = find_first_positive(-1, 42, 99)
        match result with
        | some(v) -> v
        | none -> 0
    assert(_result == 42)
    0
