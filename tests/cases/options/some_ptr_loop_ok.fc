// The guard is a plain statement-expression (no alloca), so it is loop-safe:
// 100k guarded constructions do not grow the stack.
let main = (args: str[]) ->
    let mut x = 1
    let p = &x
    let mut count = 0
    for i in 0..100000
        let o = some(p)          // guarded each iter (p is ident); p non-null → passes
        if o.is_some then
            count = count + 1
    assert(count == 100000)
    0
