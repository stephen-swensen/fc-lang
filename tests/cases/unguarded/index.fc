// `unguarded` slice index and subslice emit the bare access with no bounds check.
// For in-range indices the result matches the guarded form. Also covers an
// unguarded store (`unguarded s[i] = v`) and unguarded subslicing.
let main = (args: str[]) ->
    let mut xs = int32[5]{10, 20, 30, 40, 50}

    // unguarded read
    let a = unguarded xs[0]
    assert(a == 10)
    let b = unguarded xs[4]
    assert(b == 50)
    assert((unguarded xs[2]) == xs[2])

    // unguarded store
    unguarded xs[1] = 99
    assert(xs[1] == 99)

    // unguarded subslice
    let sub = unguarded xs[1..3]
    assert(sub.len == 2)
    assert(sub[0] == 99)
    assert(sub[1] == 30)

    // index inside a larger unguarded arithmetic expression
    let s = unguarded (xs[0] + xs[3] * 2)
    assert(s == 10 + 80)

    // unguarded index feeding an unguarded divide
    let d = unguarded (xs[3] / xs[0])
    assert(d == 4)
    0
