import io from std::
import sys from std::

let main = (args: str[]) ->
    let tmp = sys.temp_dir()!
    let path = "%s{tmp}/fc_test_io_read.txt"
    let _result =
        let f = io.open(path, "w")
        match f with
        | some(wf) ->
            io.write("abcde", wf)
            io.close(wf)
            let f2 = io.open(path, "r")
            match f2 with
            | some(rf) ->
                let mut buf = uint8[16] {}
                let n = io.read(buf, 16, rf)
                io.close(rf)
                if n == 5i64 then 42
                else (int32) n
            | none -> 2
        | none -> 1
    assert(_result == 42)
    io.remove(path)
    0
