import io from std::
import sys from std::

let main = (args: str[]) ->
    let tmp = sys.temp_dir()!

    // temp directory is writable
    assert(io.can_write(tmp))

    // nonexistent path is not writable
    assert(!io.can_write("nonexistent_xyz_should_not_exist"))

    // write a temp file and verify it's writable
    let path = "%s{tmp}/fc_test_can_write.txt"
    match io.open(path, "w") with
    | some(wf) ->
        io.write("test", wf)
        io.close(wf)
    | none -> assert(false)

    assert(io.can_write(path))
    io.remove(path)

    0
