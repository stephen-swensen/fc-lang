import io from std::
import sys from std::

let main = (args: str[]) ->
    let tmp = sys.temp_dir()!

    // nonexistent path is not readable
    assert(!io.can_read("nonexistent_xyz_should_not_exist"))

    // write a temp file and verify it's readable
    let path = "%s{tmp}/fc_test_can_read.txt"
    match io.open(path, "w") with
    | some(wf) ->
        io.write("test", wf)
        io.close(wf)
    | none -> assert(false)

    assert(io.can_read(path))
    io.remove(path)

    0
