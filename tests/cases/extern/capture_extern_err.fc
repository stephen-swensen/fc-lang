// Capturing lambda cannot be passed to extern — C function pointers can't carry context
module libc from "stdlib.h" =
    extern qsort: (any*, usize, usize, (const any*, const any*) -> i32) -> void

let main = (args: str[]) ->
    let offset = 10
    let mut nums = i32[3] { 3, 1, 2 }
    libc.qsort(nums.ptr, 3usize, (usize) sizeof(i32),
        (a: const any*, b: const any*) ->
            (*(const i32*) a + offset) - (*(const i32*) b + offset))
    0
