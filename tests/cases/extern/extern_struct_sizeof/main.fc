// Test: sizeof on extern struct
module t from "time.h" define "_POSIX_C_SOURCE" "200809L" =
    extern struct timespec =
        tv_sec: i64
        tv_nsec: i64

let main = (args: str[]) ->
    let s = sizeof(t.timespec)
    // struct timespec is 16 bytes on 64-bit Linux (two i64 fields)
    if s == 16 then 0 else (i32) s
