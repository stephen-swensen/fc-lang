// Test: sizeof on extern struct
module t from "time.h" define "_POSIX_C_SOURCE" "200809L" =
    extern struct timespec =
        tv_sec: int64
        tv_nsec: int64

import timespec from t

let main = (args: str[]) ->
    let s = sizeof(timespec)
    // struct timespec is 16 bytes on 64-bit Linux (two int64 fields)
    if s == 16 then 0 else (int32)s
