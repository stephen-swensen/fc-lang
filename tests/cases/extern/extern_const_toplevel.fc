// Test: extern constants are valid top-level initializers
module c from "fcntl.h" =
    extern O_RDONLY: int64
    extern O_WRONLY: int64

let flags = c.O_RDONLY
let combined = c.O_RDONLY | c.O_WRONLY

let main = (args: str[]) ->
    assert(flags == c.O_RDONLY)
    assert(combined == (c.O_RDONLY | c.O_WRONLY))
    0
