// Test: extern struct as function parameter and return value
import timespec from t

module t from "time.h" define "_POSIX_C_SOURCE" "200809L" =
    extern struct timespec =
        tv_sec: int64
        tv_nsec: int64

let make_ts = (sec: int64, nsec: int64) ->
    timespec { tv_sec = sec, tv_nsec = nsec }

let get_sec = (ts: timespec) ->
    ts.tv_sec

let main = (args: str[]) ->
    let ts = make_ts(42, 100)
    let s = get_sec(ts)
    if s == 42 then 0 else 1
