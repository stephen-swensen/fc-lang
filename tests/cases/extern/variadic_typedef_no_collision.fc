// Regression: a variadic extern and a non-variadic extern that share the same
// base signature must not collide in the generated function-type typedef name.
// Before the fix, `(const cstr, ...) -> i32` and `(const cstr) -> i32`
// both mangled to fc_fn_u8_t_ptr__i32_t and emitted a duplicate typedef,
// breaking compilation under -Wall -Werror (the spec's canonical printf example
// fails this way in any program that also links stdlib's `remove`).
module c from "stdio.h" =
    extern printf: (const cstr, ...) -> i32
    extern remove: (const cstr) -> i32

let main = (args: str[]) ->
    c.printf(c"variadic ok: %d\n", 7)
    c.remove(c"/tmp/fc_nonexistent_collision_test")
    0
