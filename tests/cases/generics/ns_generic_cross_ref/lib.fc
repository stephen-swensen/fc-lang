// Namespaced module with generic structs and unions that cross-reference
// each other. Tests all four combinations: struct->struct, union->struct,
// union->union. (struct->union requires a separate pass2 inference fix.)
namespace acme::

module containers =

    // struct referencing struct
    struct inner =
        x: 'a
        y: 'a

    struct outer =
        ptr: inner<'a>*

    struct pair =
        fst: inner<'a>
        snd: inner<'a>

    let create = (a: 'a, b: 'a) ->
        let i = alloc(inner { x = a, y = b })!
        outer { ptr = i }

    let sum_inner = (o: outer<int32>) ->
        o.ptr->x + o.ptr->y

    let make_pair = (a: 'a, b: 'a, c: 'a, d: 'a) ->
        pair { fst = inner { x = a, y = b }, snd = inner { x = c, y = d } }

    let pair_sum = (p: pair<int32>) ->
        p.fst.x + p.fst.y + p.snd.x + p.snd.y

    // union referencing struct
    union wrapped =
        | val(inner<'a>)
        | empty

    let wrap = (x: 'a, y: 'a) ->
        wrapped<'a>.val(inner { x = x, y = y })

    let unwrap_x = (w: wrapped<int32>) ->
        match w with
        | val(i) -> i.x
        | empty -> 0

    // union referencing union
    union maybe =
        | some_wrapped(wrapped<'a>)
        | nothing

    let nest = (x: 'a, y: 'a) ->
        maybe<'a>.some_wrapped(wrapped<'a>.val(inner { x = x, y = y }))

    let unnest_x = (m: maybe<int32>) ->
        match m with
        | some_wrapped(w) ->
            match w with
            | val(i) -> i.x
            | empty -> 0
        | nothing -> 0
