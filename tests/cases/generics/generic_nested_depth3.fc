// Generic function calling generic function at depth 3.
// Regression test: three-deep generic call chain (reduce -> try_reduce -> fold)
// where each callee is resolved via self-qualified name in a deeply nested module.
module a =
    module b =
        module c =
            let fold = (s: const 'a[], init: 'b, f: ('b, 'a) -> 'b) ->
                let mut acc = init
                for e in s do
                    acc = f(acc, e)
                acc

            let try_reduce = (s: const 'a[], f: ('a, 'a) -> 'a) ->
                if s.len == 0 then none('a)
                else some(c.fold(s[1..s.len], s[0], f))

            let reduce = (s: const 'a[], f: ('a, 'a) -> 'a) ->
                c.try_reduce(s, f)!

            let try_first = (s: const 'a[]) ->
                if s.len == 0 then none('a)
                else some(s[0])

            let first = (s: const 'a[]) ->
                c.try_first(s)!

let main = (args: str[]) ->
    let s = i32[4] { 10, 20, 30, 40 }
    assert(a.b.c.first(s) == 10)
    assert(a.b.c.reduce(s, (x: i32, y: i32) -> x + y) == 100)

    // Multiple instantiations at different types
    let bools = bool[3] { true, false, true }
    assert(a.b.c.first(bools))
    assert(a.b.c.reduce(bools, (x: bool, y: bool) -> x && y) == false)
    0
