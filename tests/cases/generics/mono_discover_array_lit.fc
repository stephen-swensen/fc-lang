// Item 6: an array literal of a generic struct instance inside a generic body.
// discover_in_expr had no EXPR_ARRAY_LIT case at all, so neither the element
// expressions (the box {...} struct literals) nor the element type box<int64>
// were walked during transitive discovery -> undefined `box__5_int64`. The
// array element type appears only inside total's body. Two instantiations.
struct box =
    v: 'a

let total = (x: 'a) ->
    let arr = box<'a>[3] { box { v = x }, box { v = x }, box { v = x } }
    arr[0].v + arr[1].v + arr[2].v

let main = (args: str[]) ->
    assert(total(7i64) == 21i64)
    assert(total(2i16) == 6i16)   // distinct instantiation: box<int16>
    0
