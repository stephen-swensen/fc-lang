union maybe =
    | just('a)
    | nothing

let main = (args: str[]) ->
    let _result =
        let x = maybe<i32>.just(42)
        let y = maybe<i32>.nothing
        match x with
        | just(v) ->
            match y with
            | just(_) -> 0
            | nothing -> v
        | nothing -> 0
    assert(_result == 42)
    0
