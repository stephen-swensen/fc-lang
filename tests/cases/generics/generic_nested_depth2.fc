// Generic function calling generic function inside a depth-2 module.
// Regression test: monomorph/codegen must resolve self-qualified generic
// calls (e.g. inner.try_first from inner.first) when the module is nested
// two levels deep.
module outer =
    module inner =
        let try_first = (s: const 'a[]) ->
            if s.len == 0 then none('a)
            else some(s[0])

        let first = (s: const 'a[]) ->
            inner.try_first(s)!

        private let identity = (x: 'a) -> x

        let apply_identity = (x: 'a) ->
            inner.identity(x)

        let fold = (s: const 'a[], init: 'b, f: ('b, 'a) -> 'b) ->
            let mut acc = init
            for e in s do
                acc = f(acc, e)
            acc

        // Two type-var sets: 'a from the slice, 'b = i32 from init
        let sum = (s: const i32[]) ->
            inner.fold(s, 0, (acc: i32, x: i32) -> acc + x)

let main = (args: str[]) ->
    let s = i32[3] { 10, 20, 30 }
    assert(outer.inner.first(s) == 10)
    assert(outer.inner.apply_identity(42) == 42)
    assert(outer.inner.sum(s) == 60)

    let empty = i32[0] {}
    assert(outer.inner.try_first(empty).is_none)
    0
