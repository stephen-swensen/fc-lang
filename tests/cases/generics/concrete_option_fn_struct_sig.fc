// Item 8c (hardest case): an option of a function whose signature uses a struct
// BY VALUE (point param), embedded by value in a generic struct. The old codegen
// split fn typedefs into two phases — struct-using fn typedefs were deferred
// until AFTER all struct defs — so a struct embedding option<(point)->i32> by
// value could never be ordered correctly. Removing the split (fn-ptr typedefs
// only need their aggregates forward-declared, which they always are) lets the
// fn typedef, its option body, and the embedding struct all emit in order.
struct point =
    x: i32
    y: i32

struct optbox =
    v: 'a?

let mk = (p: point) -> p.x + p.y

let main = (args: str[]) ->
    let h = optbox { v = some(mk) }
    let p = point { x = 20, y = 22 }
    assert(h.v!(p) == 42)
    0
