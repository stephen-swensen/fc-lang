// The idiomatic instantiation pattern: wrap the generic function in a lambda.
let identity = (x: 'a) -> x
let apply_it = (f: (i32) -> i32, n: i32) -> f(n)

let main = (args: str[]) ->
    let direct = identity(42)            // generic call is fine
    assert(direct == 42)
    let viaWrap = apply_it((x: i32) -> identity(x), 9)
    assert(viaWrap == 9)
    0
