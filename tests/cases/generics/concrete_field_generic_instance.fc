// Item 8a: a CONCRETE (non-generic) struct whose fields name generic instances.
// Concrete decls are excluded from the mono discovery/ordering machinery, so the
// field stubs (box<...>) were never canonicalized to their mangled C names. The
// single-level case (box<i32>) happened to resolve, but a NESTED instance
// (box<box<i32>>) emitted the raw template name `box` -> "unknown type name".
// Root cause: mangle_type_name dropped a STUB's type_args, so the nested stub
// arg mangled to the bare base name and the mono lookup missed. Fixed by making
// mangle_type_name recurse into stub type_args (base "__" lp(arg)*), matching the
// instance's own mangling. i32 vs i64 fields prove the names stay injective.
struct box =
    v: 'a

struct holder =
    a: box<i32>
    b: box<box<i32> >
    c: box<box<i64> >
    d: box<box<box<i32> > >

let main = (args: str[]) ->
    let h = holder {
        a = box { v = 1 },
        b = box { v = box { v = 2 } },
        c = box { v = box { v = 3i64 } },
        d = box { v = box { v = box { v = 4 } } }
    }
    assert(h.a.v == 1)
    assert(h.b.v.v == 2)
    assert(h.c.v.v == 3i64)
    assert(h.d.v.v.v == 4)
    0
