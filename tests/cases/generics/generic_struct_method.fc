struct pair =
    first: 'a
    second: 'b

let get_first = (p: pair<int32, bool>) -> p.first
let get_second = (p: pair<int32, bool>) -> p.second

let main = (args: str[]) ->
    let _result =
        let p = pair { first = 42, second = true }
        let f = get_first(p)
        let s = get_second(p)
        if s then f else 0
    assert(_result == 42)
    0
