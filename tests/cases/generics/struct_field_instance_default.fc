// A generic instance field reached only via default() — the instance must still
// be emitted even though it is never constructed with a literal.
struct box =
    value: 'a
struct holder =
    b: box<i64>
    tag: i32
let main = (args: str[]) ->
    let h = default(holder)
    assert(h.b.value == 0i64 && h.tag == 0)
    0
