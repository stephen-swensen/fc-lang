// Test implicit widening for concrete params in generic functions
// e.g. get(list, 0) where index: i64 should auto-widen i32 literal

let pick = (a: 'a, index: i64) ->
    if index == 0 then a
    else a

let add64 = (x: 'a, offset: i64) ->
    offset

let main = (args: str[]) ->
    // i32 literal 0 widens to i64 for concrete param
    let r1 = pick(42, 0)
    // i32 literal 2 widens to i64
    let r2 = pick(10, 2)
    // explicit i64 still works
    let r3 = add64(10, 5i64)
    // i32 var widens to i64
    let idx = 3
    let r4 = pick(99, idx)
    // r1=42, r2=10, r3=5, r4=99
    // 42 + 10 + 5 + 99 = 156
    assert(r1 + r2 + (i32) r3 + r4 == 156)
    0
