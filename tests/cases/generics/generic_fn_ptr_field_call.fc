// Calling a function pointer field on a generic struct directly.
struct hasher =
    hash: ('a) -> i64
    eq: ('a, 'a) -> bool

let call_hash = (h: hasher<'a>, key: 'a) ->
    h.hash(key)

let call_eq = (h: hasher<'a>, a: 'a, b: 'a) ->
    h.eq(a, b)

let main = (args: str[]) ->
    let h = hasher { hash = (x: i32) -> (i64) x, eq = (a: i32, b: i32) -> a == b }
    assert(call_hash(h, 42) == 42i64)
    assert(call_eq(h, 5, 5))
    assert(!call_eq(h, 5, 6))
    0
