import io from std::

let main = (args: str[]) ->
    let f = io.open("/tmp/fc_test_io_write_file.txt", "w")
    match f with
    | some(wf) ->
        io.write("hello\n", wf)
        io.close(wf)
        let f2 = io.open("/tmp/fc_test_io_write_file.txt", "r")
        match f2 with
        | some(rf) ->
            let mut buf = uint8[256] {}
            let n = io.read(buf, 256, rf)
            io.close(rf)
            if n == 6i64 then 42
            else (int32)n
        | none -> 2
    | none -> 1
