union shape =
    | circle(int32)
    | square(int32)

let main = (args: str[]) ->
    let _result =
        let s = alloc(shape.circle(42))
        let mut r = 0
        match s with
        | some(p) ->
            r = r + 1
            match *p with
            | circle(v) ->
                if v == 42 then r = r + 2
            | square(_) -> assert(false)
            free(p)
        | none -> assert(false)
        let s2 = alloc(shape.square(10))
        match s2 with
        | some(p2) ->
            match *p2 with
            | circle(_) -> assert(false)
            | square(v) ->
                if v == 10 then r = r + 4
            free(p2)
        | none -> assert(false)
        r
    assert(_result == 7)
    0
