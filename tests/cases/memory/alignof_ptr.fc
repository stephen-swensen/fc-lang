let main = (args: str[]) ->
    let ap = alignof(i32*)
    // pointer alignment is platform-dependent but at least 4
    assert(ap >= 4i64)

    // all pointer types have the same alignment
    assert(alignof(i8*) == alignof(i64*))
    assert(alignof(i32*) == alignof(bool*))
    assert(alignof(i32*) == alignof(any*))

    0
