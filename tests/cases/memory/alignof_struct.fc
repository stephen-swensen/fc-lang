struct pair =
    a: i32
    b: i32

struct mixed =
    x: i8
    y: i64

let main = (args: str[]) ->
    // struct alignment is at least the alignment of its most-aligned field
    assert(alignof(pair) >= alignof(i32))
    assert(alignof(mixed) >= alignof(i64))

    // struct alignment is consistent with sizeof (size is a multiple of alignment)
    assert(sizeof(pair) % alignof(pair) == 0i64)
    assert(sizeof(mixed) % alignof(mixed) == 0i64)

    0
