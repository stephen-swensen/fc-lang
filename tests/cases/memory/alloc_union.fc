union shape =
    | circle(int32)
    | square(int32)

let main = (args: str[]) ->
    let _result =
        let s = alloc(shape)!
        *s = shape.circle(7)
        let r = match *s with
            | circle(v) -> v
            | square(v) -> v
        free(s)
        r
    assert(_result == 7)
    0
