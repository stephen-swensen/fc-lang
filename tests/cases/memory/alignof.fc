let main = (args: str[]) ->
    let a1 = alignof(i8)
    let a2 = alignof(i16)
    let a4 = alignof(i32)
    let a8 = alignof(i64)
    let ab = alignof(bool)

    // i8 alignment is always 1
    assert(a1 == 1i64)

    // i16 alignment is at least 2
    assert(a2 >= 2i64)

    // i32 alignment is at least 4
    assert(a4 >= 4i64)

    // i64 alignment is at least 8
    assert(a8 >= 8i64)

    // bool alignment is at least 1
    assert(ab >= 1i64)

    // unsigned types have same alignment as signed
    assert(alignof(u8) == alignof(i8))
    assert(alignof(u16) == alignof(i16))
    assert(alignof(u32) == alignof(i32))
    assert(alignof(u64) == alignof(i64))

    // platform-width types
    assert(alignof(isize) >= 4i64)
    assert(alignof(usize) >= 4i64)
    assert(alignof(isize) == alignof(usize))

    0
