// heap allocation of an option-typed array: alloc(T?[N] { ... })
let main = (args: str[]) ->
    let opts = alloc(i32?[4] { some(10), none(i32), some(3), some(9) })!
    let mut sum = 0
    let mut nones = 0
    for o in opts do
        match o with
        | some(v) -> sum = sum + v
        | none    -> nones = nones + 1
    free(opts)
    assert(sum == 22)
    assert(nones == 1)
    0
