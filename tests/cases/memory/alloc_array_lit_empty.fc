let main = (args: str[]) ->
    let _result =
        let arr = alloc(int32[4] { })
        let mut r = 0
        match arr with
        | some(v) ->
            r = r + 1
            if v[0] == 0 then r = r + 1
            if v[3] == 0 then r = r + 1
            free(v)
        | none -> assert(false)
        r
    assert(_result == 3)
    0
