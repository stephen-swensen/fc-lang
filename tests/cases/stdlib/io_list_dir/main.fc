import io from std::
import sys from std::

// Compare two str values byte-for-byte.
let str_eq = (a: const str, b: const str) ->
    if a.len != b.len then false
    else
        let mut i = 0i64
        let mut eq = true
        loop
            if i >= a.len then break
            if a[i] != b[i] then
                eq = false
                break
            i = i + 1
        eq

let main = (args: str[]) ->
    let tmp = sys.temp_dir()!
    let dir = "%s{tmp}/fc_test_list_dir"
    let path_a = "%s{tmp}/fc_test_list_dir/a.txt"
    let path_b = "%s{tmp}/fc_test_list_dir/b.txt"
    let path_c = "%s{tmp}/fc_test_list_dir/c.txt"
    let missing = "%s{tmp}/fc_test_list_dir_does_not_exist"

    // Start fresh: remove any leftover files from a prior run and (re)create.
    // If the directory doesn't exist yet, remove() calls are no-ops.
    io.remove(path_a)
    io.remove(path_b)
    io.remove(path_c)
    c.rmdir((cstr) dir)
    assert(io.mkdir(dir))

    // Listing an empty directory should return some([]).
    match io.list_dir(dir) with
    | none -> return 1
    | some(names) ->
        assert(names.len == 0)
        free(names)

    // Create three files.
    let touch = (name: const str) ->
        match io.open(name, "w") with
        | some(f) ->
            io.close(f)
            true
        | none -> false
    if !touch(path_a) then return 2
    if !touch(path_b) then return 2
    if !touch(path_c) then return 2

    // List and verify: expect exactly a.txt, b.txt, c.txt (no ".", "..").
    match io.list_dir(dir) with
    | none -> return 3
    | some(names) ->
        assert(names.len == 3)
        let mut saw_a = false
        let mut saw_b = false
        let mut saw_c = false
        for n in names
            if str_eq(n, "a.txt") then saw_a = true
            else if str_eq(n, "b.txt") then saw_b = true
            else if str_eq(n, "c.txt") then saw_c = true
            else return 4
        assert(saw_a && saw_b && saw_c)
        for n in names
            free(n)
        free(names)

    // Listing a nonexistent directory should return none.
    let nonexistent = io.list_dir(missing)
    assert(nonexistent.is_none)

    // Cleanup.
    io.remove(path_a)
    io.remove(path_b)
    io.remove(path_c)
    c.rmdir((cstr) dir)

    0

#if os == "windows"
module c from "direct.h" =
    extern _rmdir as rmdir: (const cstr) -> int32
#else
module c from "unistd.h" =
    extern rmdir: (const cstr) -> int32
#end
