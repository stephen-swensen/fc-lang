import sys from std::
import io from std::

let main = (args: str[]) ->
    // temp_dir falls back to /tmp on POSIX, and Windows always sets TEMP/TMP,
    // so this should never be none in any reasonable test environment.
    match sys.temp_dir() with
    | none -> return 1
    | some(tmp) ->
        assert(tmp.len > 0)

        // Confirm the returned path is actually a writable directory by
        // round-tripping a file through it.
        let path = "%s{tmp}/fc_test_temp_dir_probe.txt"
        match io.open(path, "w") with
        | none -> return 2
        | some(f) ->
            io.write("ok", f)
            io.close(f)
        io.remove(path)
        void()

    0
