import math from std::

let main = (args: str[]) ->
    // Constants
    assert(math.abs(math.pi - 3.14159265358979323846) < 0.000001)
    assert(math.abs(math.e - 2.71828182845904523536) < 0.000001)

    // sqrt
    assert(math.sqrt(4.0) == 2.0)
    assert(math.sqrt(9.0) == 3.0)
    assert(math.sqrt(0.0) == 0.0)
    assert(math.sqrt(1.0) == 1.0)

    // abs
    assert(math.abs(3.5) == 3.5)
    assert(math.abs(-3.5) == 3.5)
    assert(math.abs(0.0) == 0.0)

    // pow
    assert(math.pow(2.0, 3.0) == 8.0)
    assert(math.pow(2.0, 0.0) == 1.0)
    assert(math.pow(3.0, 2.0) == 9.0)
    assert(math.abs(math.pow(2.0, -1.0) - 0.5) < 0.000001)

    // min / max
    assert(math.min(1.0, 2.0) == 1.0)
    assert(math.min(2.0, 1.0) == 1.0)
    assert(math.min(-1.0, 1.0) == -1.0)
    assert(math.max(1.0, 2.0) == 2.0)
    assert(math.max(2.0, 1.0) == 2.0)
    assert(math.max(-1.0, 1.0) == 1.0)

    0
