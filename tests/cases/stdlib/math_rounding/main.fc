import math from std::

let main = (args: str[]) ->
    // floor
    assert(math.floor(2.7) == 2.0)
    assert(math.floor(2.0) == 2.0)
    assert(math.floor(-2.3) == -3.0)
    assert(math.floor(-2.0) == -2.0)

    // ceil
    assert(math.ceil(2.3) == 3.0)
    assert(math.ceil(2.0) == 2.0)
    assert(math.ceil(-2.7) == -2.0)
    assert(math.ceil(-2.0) == -2.0)

    // round
    assert(math.round(2.3) == 2.0)
    assert(math.round(2.7) == 3.0)
    assert(math.round(2.5) == 3.0)
    assert(math.round(-2.5) == -3.0)
    assert(math.round(0.0) == 0.0)

    0
