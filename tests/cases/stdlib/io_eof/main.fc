import io from std::

let main = (args: str[]) ->
    // Write a small file
    let f = io.open("/tmp/fc_test_eof.txt", "w")
    match f with
    | some(wf) ->
        io.write("hi", wf)
        io.close(wf)
    | none -> return 1

    let f2 = io.open("/tmp/fc_test_eof.txt", "r")
    match f2 with
    | some(rf) ->
        // Not at EOF yet
        assert(io.eof(rf) == false)

        // Read all content
        let mut buf = uint8[16] {}
        io.read(buf, 16, rf)

        // After reading past end, eof should be true
        assert(io.eof(rf) == true)

        io.close(rf)
    | none -> return 2

    io.remove("/tmp/fc_test_eof.txt")
    0
