import io from std::
import sys from std::

let main = (args: str[]) ->
    let tmp = sys.temp_dir()!
    let path = "%s{tmp}/fc_test_eof.txt"

    // Write a small file
    let f = io.open(path, "w")
    match f with
    | some(wf) ->
        io.write("hi", wf)
        io.close(wf)
    | none -> return 1

    let f2 = io.open(path, "r")
    match f2 with
    | some(rf) ->
        // Not at EOF yet
        assert(io.eof(rf) == false)

        // Read all content
        let mut buf = uint8[16] {}
        io.read(buf, 16, rf)

        // After reading past end, eof should be true
        assert(io.eof(rf) == true)

        io.close(rf)
    | none -> return 2

    io.remove(path)
    0
