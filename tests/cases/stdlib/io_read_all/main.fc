import io from std::
import sys from std::

let main = (args: str[]) ->
    let tmp = sys.temp_dir()!
    let path = "%s{tmp}/fc_test_read_all.txt"
    let payload = "abcdefghij"

    // Write a known payload.
    match io.open(path, "w") with
    | none -> return 1
    | some(wf) ->
        io.write(payload, wf)
        io.close(wf)

    // read_all returns the whole file as a heap-allocated str.
    match io.read_all(path) with
    | none -> return 2
    | some(buf) ->
        assert(buf.len == payload.len)
        let mut i = 0i64
        loop
            if i >= buf.len then break
            assert(buf[i] == payload[i])
            i = i + 1
        free(buf)

    io.remove(path)

    // read_all on a missing path should return none rather than crash.
    let missing = "%s{tmp}/fc_test_read_all_does_not_exist.txt"
    assert(io.read_all(missing).is_none)

    0
