import hash_set from std::data
import array_list from std::data

// Containers are reference-semantics handles: make() returns a pointer, and the
// pointer is a plain `let` (capturable in closures by copy) while the pointee
// stays mutable through it. Mutations made through the handle are observed by
// every alias and every capturing closure — including after a grow/rehash that
// reallocates the backing buffer.

let main = (args: str[]) ->
    // hash_set: mirrors the prime-sieve pattern. Capture the handle in a
    // closure, then mutate the set elsewhere; the closure sees the change.
    let sieve = hash_set.make(
        (value: int64) -> value ^ (int64)((uint64) value >> 32),
        (x: int64, y: int64) -> x == y)
    let is_composite = (candidate: int64) ->
        hash_set.any(sieve, (p: int64) -> candidate % p == 0)

    assert(!is_composite(9))       // empty set: nothing divides 9
    hash_set.add(sieve, 3i64)
    assert(is_composite(9))         // closure reflects the add
    assert(!is_composite(7))
    hash_set.add(sieve, 7i64)
    assert(is_composite(7))

    // Force a rehash (reallocates buckets) while aliases are live.
    for k in 0..40
        hash_set.add(sieve, (int64) k * 2 + 100)
    assert(is_composite(102))       // still consistent after rehash
    hash_set.destroy(sieve)

    // array_list: reader closures capture the handle and observe growth, even
    // across the realloc that happens when len passes the initial capacity (8).
    let xs = array_list.make<int32>()
    let size = () -> array_list.len(xs)
    let total = () -> array_list.fold_left(xs, 0, (a: int32, b: int32) -> a + b)
    for i in 1..21
        array_list.add(xs, i)
    assert(size() == 20)
    assert(total() == 210)          // 1 + 2 + ... + 20
    array_list.destroy(xs)
    0
