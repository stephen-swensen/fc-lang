// Function and lambda parameters named after C keywords must be escaped in
// the parameter declaration and at every reference inside the body. The FC
// lookup name stays the source spelling, so references still resolve.
let compute = (register: int32, volatile: int32, signed: int32) ->
    register * volatile + signed

// A keyword-named parameter referenced through nested expressions and a
// closure capture.
let scale = (double: int32) ->
    let f = (short: int32) -> short * double   // capture keyword-named param
    f(3)

let main = (args: str[]) ->
    assert(compute(6, 7, 5) == 47)
    assert(scale(4) == 12)

    // Lambda with keyword params, invoked directly.
    let g = (static: int32, auto: int32) -> static - auto
    assert(g(10, 3) == 7)
    0
