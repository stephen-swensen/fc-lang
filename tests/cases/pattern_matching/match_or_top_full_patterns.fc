let classify = (o: int32?) ->
    match o with
    | some(1) | some(2) -> 10
    | some(_) -> 20
    | none -> 0

let main = (args: str[]) ->
    let n = default(int32?)
    assert(classify(some(1)) == 10)
    assert(classify(some(2)) == 10)
    assert(classify(some(7)) == 20)
    assert(classify(n) == 0)
    0
