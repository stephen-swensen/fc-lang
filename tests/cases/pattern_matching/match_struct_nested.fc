struct point =
    x: i32
    y: i32

struct rect =
    origin: point
    w: i32

let main = (args: str[]) ->
    let _result =
        let r = rect { origin = point { x = 0, y = 5 }, w = 10 }
        match r with
        | { origin = { x = 0, y = 0 }, w = w } -> w
        | { origin = { x = 0, y = y }, w = w } -> y + w
        | { origin = { x = x } } -> x
    assert(_result == 15)
    0
