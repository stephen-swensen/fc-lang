// Guards on boolean literal patterns.
let mut counter = 0

let describe = (b: bool) ->
    counter = counter + 1
    match b with
    | true when counter < 3 -> 0
    | true -> 1
    | false -> 2

let main = (args: str[]) ->
    assert(describe(true) == 0)    // counter=1
    assert(describe(true) == 0)    // counter=2
    assert(describe(true) == 1)    // counter=3, guard false
    assert(describe(false) == 2)
    0
