struct point =
    x: int32
    y: int32

union shape =
    | circle(point)
    | line(point)

struct canvas =
    bg: int32
    shape: shape

let extract = (c: canvas) ->
    match c with
    | { shape = circle({ x = x, y = y }) } -> x + y
    | { shape = line({ x = 0, y = y }) } -> y
    | { shape = line({ x = x }) } -> x
    | _ -> 0

let main = (args: str[]) ->
    let c1 = canvas { bg = 0, shape = shape.circle(point { x = 3, y = 7 }) }
    let c2 = canvas { bg = 0, shape = shape.line(point { x = 0, y = 20 }) }
    let c3 = canvas { bg = 0, shape = shape.line(point { x = 5, y = 99 }) }
    assert(extract(c1) + extract(c2) + extract(c3) == 35)
    0
