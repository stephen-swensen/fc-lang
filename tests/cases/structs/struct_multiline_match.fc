// Multiline struct literal inside a match arm
struct point =
    x: int32
    y: int32

let main = (args: str[]) ->
    let _result =
        let n = 1
        let p = match n with
            | 1 -> point {
                x = 10,
                y = 20
            }
            | _ -> point {
                x = 0,
                y = 0
            }
        p.x + p.y
    assert(_result == 30)
    0
