// Mix of single-line and multiline struct literals in same function
struct point =
    x: int32
    y: int32

let main = (args: str[]) ->
    let _result =
        let a = point { x = 1, y = 2 }
        let b = point {
            x = 3,
            y = 4
        }
        a.x + a.y + b.x + b.y
    assert(_result == 10)
    0
