// Expressions in multiline struct field values
struct point =
    x: i32
    y: i32

let double = (n: i32) -> n * 2

let main = (args: str[]) ->
    let _result =
        let p = point {
            x = 1 + 2 + 3,
            y = double(10)
        }
        p.x + p.y
    assert(_result == 26)
    0
