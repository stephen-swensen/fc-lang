// Nested multiline struct literals
struct inner =
    x: i32
    y: i32

struct outer =
    a: inner
    b: i32

let main = (args: str[]) ->
    let _result =
        let o = outer {
            a = inner {
                x = 1,
                y = 2
            },
            b = 3
        }
        o.a.x + o.a.y + o.b
    assert(_result == 6)
    0
