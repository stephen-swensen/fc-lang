union shape =
    | circle(int32)
    | square(int32)

let main = (args: str[]) ->
    let a = shape.circle(5)
    let b = shape.circle(5)
    let c = shape.square(5)
    let d = shape.circle(3)
    let mut r = 0
    if a == b then r = r + 1 else r = r
    if a != c then r = r + 2 else r = r
    if a != d then r = r + 4 else r = r
    r
