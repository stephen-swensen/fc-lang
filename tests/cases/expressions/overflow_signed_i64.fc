let main = (args: str[]) ->
    let _result =
        let max = 9223372036854775807i64
        let result = max + 1i64
        // INT64_MIN is -9223372036854775808, which can't be a literal
        // But result should be negative (overflow wraps)
        if result < 0i64 then 1 else 0
    assert(_result == 1)
    0
