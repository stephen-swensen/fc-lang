// Narrow-width (int8/uint8/int16/uint16) arithmetic must wrap/truncate to the
// FC result type even when the result is consumed directly, not stored through
// a binding. C integer promotion widens these operands to `int`, so the emitted
// code must cast the result back (and route narrow multiply through `unsigned`
// to avoid signed-overflow UB). See spec/hist/audit-2026-06-rc4.md item 1.
//
// The opaque identity helpers defeat constant folding so the assertions
// exercise the emitted runtime arithmetic rather than compile-time evaluation.

let o_u8  = (x: uint8)  -> x
let o_u16 = (x: uint16) -> x
let o_i8  = (x: int8)   -> x
let o_i16 = (x: int16)  -> x

let main = (args: str[]) ->
    // --- unsigned add wraps when consumed directly ---
    assert(o_u8(200u8) + o_u8(100u8) == 44u8)
    assert(o_u16(60000u16) + o_u16(10000u16) == 4464u16)

    // --- unsigned subtract wraps (underflow) ---
    assert(o_u8(10u8) - o_u8(20u8) == 246u8)
    assert(o_u16(0u16) - o_u16(1u16) == 65535u16)

    // --- unsigned multiply wraps ---
    assert(o_u8(20u8) * o_u8(20u8) == 144u8)               // 400 mod 256
    assert(o_u16(1000u16) * o_u16(1000u16) == 16960u16)    // 1_000_000 mod 65536

    // --- unsigned left shift truncates ---
    assert(o_u8(200u8) << 1u8 == 144u8)                    // 400 mod 256
    assert(o_u16(60000u16) << 1u16 == 54464u16)            // 120000 mod 65536

    // --- signed multiply: correct result, no int-overflow UB ---
    assert(o_i8(-1i8) * o_i8(-1i8) == 1i8)
    assert(o_i16(-1i16) * o_i16(-1i16) == 1i16)
    assert(o_i8(50i8) * o_i8(50i8) == -60i8)               // 2500 wraps
    assert(o_i16(20000i16) * o_i16(20000i16) == -31744i16) // 4e8 wraps

    // --- signed add/sub wrap when consumed directly ---
    assert(o_i8(127i8) + o_i8(1i8) == -128i8)
    assert(o_i16(32767i16) + o_i16(1i16) == -32768i16)
    assert(o_i8(-100i8) - o_i8(50i8) == 106i8)

    // --- signed left shift truncates ---
    assert(o_i8(64i8) << 1i8 == -128i8)                    // 128 wraps

    // --- ordinary (non-overflowing) division/modulo are unaffected ---
    assert(o_i8(100i8) / o_i8(3i8) == 33i8)
    assert(o_u16(60000u16) % o_u16(7u16) == 3u16)
    // Narrow signed `min / -1` wraps to min (audit item 15, resolved as wrap):
    // the divisor guard substitutes the wrapped value rather than dividing, so
    // this holds at the operand's own width on any target — including a 16-bit
    // `int` where int16.min/-1 would otherwise be a genuine SIGFPE. Full
    // cross-width coverage lives in expressions/div_overflow_wrap.fc.
    assert(o_i8(-128i8) / o_i8(-1i8) == -128i8)
    assert(o_i16(-32768i16) / o_i16(-1i16) == -32768i16)
    assert(o_i8(-128i8) % o_i8(-1i8) == 0i8)

    // --- nested narrow arithmetic truncates at each step ---
    assert((o_u8(200u8) + o_u8(100u8)) * o_u8(3u8) == 132u8) // (44) * 3

    0
