// `a<b>(c)` on a numeric value parses as a generic call (the <...> reads as
// type arguments) and fails because `a` is not a function. There is no valid
// comparison reading to suggest: `(a < b) > c` would order a bool, which is
// itself a type error, so the diagnostic stays the plain non-callable message.
let main = (args: str[]) ->
    let a = 3
    let b = 4
    let c = 5
    let r = a<b>(c)
    r
