// Indirect calls (through a function value) evaluate the callee first, then the
// arguments left-to-right, each exactly once.
let bump = (c: i32*) ->
    *c = *c + 1
    *c

let three = (a: i32, b: i32, c: i32) ->
    a * 100 + b * 10 + c

let main = (args: str[]) ->
    // Bind the function as a value so the call goes through the fat-pointer
    // (indirect) path, then pass side-effecting arguments.
    let f = three
    let mut c = 0
    assert(f(bump(&c), bump(&c), bump(&c)) == 123)
    assert(c == 3)

    // Lambda value, same property.
    let g = (a: i32, b: i32) -> a * 10 + b
    let mut d = 0
    assert(g(bump(&d), bump(&d)) == 12)
    assert(d == 2)
    0
