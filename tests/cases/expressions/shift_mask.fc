let main = (args: str[]) ->
    let _result =
        let mut r = 0
        // 1 << 32 with masking: 32 & 31 = 0, so result = 1
        let a = 1 << 32
        if a == 1 then r = r + 1
        // 1 << 31 should work normally
        let b = 1 << 31
        if b == -2147483648 then r = r + 2
        // right shift masking: 1 >> 32 with masking = 1 >> 0 = 1
        let c = 1 >> 32
        if c == 1 then r = r + 4
        r
    assert(_result == 7)
    0
