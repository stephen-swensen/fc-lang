let add = (a: i32, b: i32) ->
    a + b

let main = (args: str[]) ->
    let _result =
        let x = add(10, 20)
        let name = "result"
        let s = alloca("%s{name}=%d{x} (%T{x})")
        let mut r = 0
        if s == "result=30 (i32)" then r = r + 1
        r
    assert(_result == 1)
    0
