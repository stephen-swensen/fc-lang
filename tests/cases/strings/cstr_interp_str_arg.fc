module c from "string.h" =
    extern strlen: (const cstr) -> usize

let main = (args: str[]) ->
    let name = "world"
    let s = c"hello %s{name}!"
    let len = c.strlen(s)
    let mut r = 0
    if len == 12u then r = r + 1 else r = r
    let empty = ""
    let s2 = c"[%s{empty}]"
    let len2 = c.strlen(s2)
    if len2 == 2u then r = r + 2 else r = r
    r
