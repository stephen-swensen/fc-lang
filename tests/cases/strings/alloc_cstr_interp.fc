module c from "string.h" =
    extern strlen: (const cstr) -> usize
    extern strcmp: (const cstr, const cstr) -> int32

let main = (args: str[]) ->
    let _result =
        let x = 42
        let s = alloc(c"value: %d{x}")
        let mut r = 0
        match s with
        | some(v) ->
            if c.strcmp(v, c"value: 42") == 0 then r = r + 1
            let len = c.strlen(v)
            if len == 9u then r = r + 2
            free(v)
        | none -> assert(false)
        let name = c"world"
        let s2 = alloc(c"hello %s{name}!")
        match s2 with
        | some(v2) ->
            if c.strcmp(v2, c"hello world!") == 0 then r = r + 4
            free(v2)
        | none -> assert(false)
        r
    assert(_result == 7)
    0
