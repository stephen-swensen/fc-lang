let main = (args: str[]) ->
    let _result =
        let x = 42
        // zero-padded
        let s1 = "%08d{x}"
        let mut r = 0
        if s1 == "00000042" then r = r + 1
        // hex with 0x prefix
        let s2 = "%#x{x}"
        if s2 == "0x2a" then r = r + 2
        r
    assert(_result == 3)
    0
