let main = (args: str[]) ->
    let _result =
        let s = alloc("hello")
        let mut r = 0
        match s with
        | some(cv) ->
            let v = cv
            if v == "hello" then r = r + 1
            // verify it's a real copy (different from static)
            if v.len == 5 then r = r + 2
            free(v)
        | none -> assert(false)
        r
    assert(_result == 3)
    0
