// A (cstr[N]) cast inside a loop must reuse one backing slot hoisted to
// function entry, not extend the frame every iteration. 200_000 iterations
// of a bare unbounded (cstr) would have grown the stack until return; the
// bounded form keeps it constant. The accumulated value is exact.
module c from "string.h" =
    extern strlen: (const cstr) -> usize

let main = (args: str[]) ->
    let s = "abcdef"
    let mut acc = 0i64
    for i in 0..200000
        let cs = (cstr[8]) s
        acc = acc + (int64) c.strlen(cs)
    assert(acc == 200000i64 * 6i64)
    0
