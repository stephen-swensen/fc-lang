module c from "string.h" =
    extern strlen: (const cstr) -> usize

let main = (args: str[]) ->
    let _result =
        let x = 42
        let s = c"%d{x}"
        let len = c.strlen(s)
        let mut r = 0
        if len == 2u then r = r + 1 else r = r
        let name = c"world"
        let s2 = c"hello %s{name}!"
        let len2 = c.strlen(s2)
        if len2 == 12u then r = r + 2 else r = r
        // empty interp segments
        let s3 = c"test"
        let len3 = c.strlen(s3)
        if len3 == 4u then r = r + 2 else r = r
        r
    assert(_result == 5)
    0
