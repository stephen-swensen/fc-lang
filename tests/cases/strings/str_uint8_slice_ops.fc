let main = (args: str[]) ->
    let _result =
        let mut buf = uint8[5] { }
        buf.ptr[0] = 10u8
        buf.ptr[1] = 20u8
        buf.ptr[2] = 30u8
        buf.ptr[3] = 40u8
        buf.ptr[4] = 50u8

        let len = buf.len
        let v = buf[2]
        let sub = buf[1..3]
        let sub_len = sub.len
        let sub_v = sub[0]
        let p = buf.ptr
        let pv = *p

        let mut total = 0u8
        for x in buf
            total = total + x

        let result = (int32) len + (int32) v + (int32) sub_len + (int32) sub_v + (int32) pv + (int32) total
        result
    assert(_result == 217)
    0
