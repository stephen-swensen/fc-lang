// Two call sites with the same element types must share one tuple type.
let pair_up = (x: 'a, y: 'a) -> { x, y }

let main = (args: str[]) ->
    let p = pair_up(1, 2)
    let q = pair_up(3, 4)
    assert(p[0] + p[1] == 3)
    assert(q[0] + q[1] == 7)
    // same shape → equality is well-typed
    assert(pair_up(5, 6) == { 5, 6 })
    0
