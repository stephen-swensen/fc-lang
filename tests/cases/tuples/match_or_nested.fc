let describe = (t: {i32, bool}) ->
    match t with
    | { 1 | 2 | 3, true } -> 100
    | { _, false } -> 200
    | { n, _ } -> n

let deep = (t: {{i32, i32}, i32}) ->
    match t with
    | { { 1, y }, z } -> y + z
    | { _, z } -> z

let main = (args: str[]) ->
    assert(describe({ 2, true }) == 100)
    assert(describe({ 5, false }) == 200)
    assert(describe({ 7, true }) == 7)
    assert(deep({ { 1, 5 }, 6 }) == 11)
    assert(deep({ { 9, 5 }, 6 }) == 6)
    0
