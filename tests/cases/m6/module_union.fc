module shapes =
    union shape =
        | circle(int32)
        | square(int32)
        | empty

    let area = (s: shape) ->
        match s with
            | circle(r) -> r * r * 3
            | square(side) -> side * side
            | empty -> 0

let main = (args: int32) ->
    let c = shapes.shape.circle(5)
    let s = shapes.shape.square(4)
    let e = shapes.shape.empty
    let a1 = shapes.area(c)
    let a2 = shapes.area(s)
    let a3 = shapes.area(e)
    a1 + a2 + a3
