// Sibling access works at every nesting level
module outer =
    let a = 1

    module inner =
        let b = 2
        let sum_ab = () -> a + b

        module deep =
            let c = 3
            let sum_all = () -> a + b + c

let main = (args: str[]) ->
    let x = outer.inner.sum_ab()
    let y = outer.inner.deep.sum_all()
    x + y
