// Verify defers run on every return path
let mut trace = 0

let run = (n: int32) ->
    defer trace = trace + 100
    if n == 1 then return
    if n == 2 then return
    // fall through

let main = (args: str[]) ->
    run(1)
    assert(trace == 100)
    trace = 0
    run(2)
    assert(trace == 100)
    trace = 0
    run(3)
    assert(trace == 100)
    0
