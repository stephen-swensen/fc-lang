// C out-parameter pattern: function creates a heap value
// and writes the pointer back through T**
let create = (out: int32**) ->
    let p = alloc(int32)!
    *p = 99
    *out = p

let main = (args: int32) ->
    let mut result = default(int32*)
    create(&result)
    let v = *result
    free(result)
    v
