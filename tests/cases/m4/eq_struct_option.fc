struct point =
    x: int32
    y: int32

struct wrapper =
    p: point
    label: int32?

let main = (args: int32) ->
    let a = wrapper { p = point { x = 1, y = 2 }, label = some(10) }
    let b = wrapper { p = point { x = 1, y = 2 }, label = some(10) }
    let c = wrapper { p = point { x = 1, y = 2 }, label = none(int32) }
    let mut r = 0
    if a == b then r = r + 1 else r = r
    if a != c then r = r + 2 else r = r
    r
