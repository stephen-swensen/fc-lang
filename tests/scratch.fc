import io from std::

let println = (s:str) ->  io.write("%s{s}\n", stdout)

struct tuple2 =
    e1: 'a
    e2: 'b*

let main = (args: str[]) ->
    let x = alloc(int64)!
    //let t = (tuple2<int32,int64>*) alloc(tuple2 { e1 = 32, e2 = x })!
    let t = (const tuple2<int32,int64>*) alloc(tuple2 { e1 = 32, e2 = x })!
    let y = t->e2
    println("t: %T{t}")
    println("y: %T{y}")
    0

