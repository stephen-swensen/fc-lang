import * from std::prelude
//import * from std::types

module other =
    struct tuple2 =
        e1: 'a
        e2: 'b

import tuple2 as other_tuple2 from other

let main = (args: str[]) ->
    //let t_actual = tuple2 { e1 = 1, e2 = 'c' }
    let t = make_tuple2(1, 'c')
    let tt = other.tuple2 { e1 = 1, e2 = 'c' }
    let ttt = other_tuple2 { e1 = 1, e2 = 'c' }
    //println("t_actual: %T{t_actual}")
    println("t: %T{t}")
    println("tt: %T{tt}")
    println("ttt: %T{ttt}")

    //println("t == t_actual: %T{t == t_actual}")
    println("t == t: %T{t == t}")
    //println("t == tt: %T{t == tt}")
    println("tt == ttt: %T{tt == ttt}")
    0

