namespace std::

module sys =
    private module c from "stdlib.h" =
        extern getenv: (const cstr) -> const cstr?
        extern exit: (i32) -> void

#if os == "windows"
    // FILETIME is a 64-bit count of 100-nanosecond ticks since 1601-01-01 UTC,
    // split across two DWORDs (little-endian). Sleep/GetCurrentProcessId take
    // and return DWORDs (u32).
    private module w from "windows.h" define "WIN32_LEAN_AND_MEAN" "1" =
        extern struct _FILETIME as FILETIME =
            dwLowDateTime: u32
            dwHighDateTime: u32
        extern GetSystemTimeAsFileTime as get_system_time: (FILETIME*) -> void
        extern Sleep as win_sleep: (u32) -> void
        extern GetCurrentProcessId as get_current_pid: () -> u32
#else
    private module u from "unistd.h" =
        extern getpid: () -> i32

    private module t from "time.h" define "_POSIX_C_SOURCE" "200809L" =
        extern timespec_get: (timespec*, i32) -> i32
        extern nanosleep: (timespec*, timespec*?) -> i32
        extern struct timespec =
            tv_sec: i64
            tv_nsec: i64
#end

    // env: looks up an environment variable by name.
    // name: const str — variable name; const because env only reads it.
    // returns: const str? — the value if set, none if unset. Const because the
    //   returned str points into the process environment block.
    let env = (name: const str) ->
        match c.getenv(alloca((cstr) name)) with
        | some(cs) -> some((const str) cs)
        | none -> default(const str?)

    // exit: terminates the process immediately with the given exit code.
    // code: i32 — exit status (0 = success, nonzero = failure).
    // returns: void (never returns — the process exits).
    let exit = (code: i32) ->
        c.exit(code)

    // time: returns the current wall-clock time as milliseconds since the Unix epoch.
    // returns: i64 — milliseconds since 1970-01-01 00:00:00 UTC.
#if os == "windows"
    // Win32 GetSystemTimeAsFileTime returns 100ns ticks since 1601-01-01 UTC.
    // 116444736000000000 ticks separate 1601-01-01 from 1970-01-01.
    let time = () ->
        let mut ft = default(w.FILETIME)
        w.get_system_time(&ft)
        let hi = (i64) ft.dwHighDateTime << 32
        let lo = (i64) ft.dwLowDateTime
        ((hi | lo) - 116444736000000000i64) / 10000i64
#else
    // Uses C11 timespec_get (portable, no POSIX dependency).
    let time = () ->
        let mut ts = default(t.timespec)
        t.timespec_get(&ts, 1)
        ts.tv_sec * 1000 + ts.tv_nsec / 1000000
#end

    // temp_dir: returns the platform temp directory path.
    // Checks TMPDIR, TMP, TEMP (in order). On POSIX falls back to "/tmp"
    // since those env vars are often unset; Windows always sets TEMP/TMP.
    // returns: const str? — the temp directory path if found, none otherwise.
    let temp_dir = () ->
        match c.getenv(c"TMPDIR") with
        | some(cs) -> some((const str) cs)
        | none ->
            match c.getenv(c"TMP") with
            | some(cs) -> some((const str) cs)
            | none ->
                match c.getenv(c"TEMP") with
                | some(cs) -> some((const str) cs)
#if os == "windows"
                | none -> default(const str?)
#else
                | none -> some((const str) "/tmp")
#end

    // home_dir: returns the user's home directory path.
    // Checks HOME (Linux, macOS, MinGW), then USERPROFILE (Windows).
    // returns: const str? — the home directory path if found, none otherwise.
    let home_dir = () ->
        match c.getenv(c"HOME") with
        | some(cs) -> some((const str) cs)
        | none ->
            match c.getenv(c"USERPROFILE") with
            | some(cs) -> some((const str) cs)
            | none -> default(const str?)

    // sleep: suspends the calling thread for at least ms milliseconds.
    // ms: i64 — duration to sleep in milliseconds.
    // returns: void.
#if os == "windows"
    // Win32 Sleep takes a DWORD (u32); ms above ~49.7 days wraps.
    let sleep = (ms: i64) ->
        w.win_sleep((u32) ms)
        return
#else
    let sleep = (ms: i64) ->
        let mut req = t.timespec { tv_sec = ms / 1000, tv_nsec = (ms % 1000) * 1000000 }
        t.nanosleep(&req, default(t.timespec*?))
        return
#end

    // get_pid: returns the current process ID.
    // returns: i32 — the process ID.
#if os == "windows"
    let get_pid = () -> (i32) w.get_current_pid()
#else
    let get_pid = () -> u.getpid()
#end

