{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "FC",
  "scopeName": "source.fc",
  "patterns": [
    { "include": "#comments" },
    { "include": "#preprocessor" },
    { "include": "#strings" },
    { "include": "#char" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#types" },
    { "include": "#typevar" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.fc",
          "match": "//.*$",
          "captures": { "0": { "patterns": [ { "include": "#todo" } ] } }
        },
        {
          "name": "comment.block.fc",
          "begin": "/\\*",
          "end": "\\*/",
          "patterns": [ { "include": "#todo" } ]
        }
      ]
    },
    "todo": {
      "name": "keyword.todo.fc",
      "match": "\\b(TODO|FIXME|XXX|NOTE|HACK|BUG)\\b"
    },
    "preprocessor": {
      "name": "keyword.control.directive.fc",
      "match": "^\\s*#(if|else|end)\\b"
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.fc",
          "match": "\\b(match|with|when|if|then|else|for|in|loop|do|break|continue|return|defer)\\b"
        },
        {
          "name": "keyword.other.fc",
          "match": "\\b(let|mut|struct|union|module|namespace|import|from|as|extern|private|define|guarded|unguarded|checked|unchecked)\\b"
        },
        {
          "name": "support.function.builtin.fc",
          "match": "\\b(alloc|alloca|free|sizeof|alignof|default|assert|some|atomic_load_acquire|atomic_store_release)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        { "name": "constant.language.boolean.fc", "match": "\\b(true|false)\\b" },
        { "name": "constant.language.fc", "match": "\\b(none|void)\\b" },
        { "name": "support.variable.builtin.fc", "match": "\\b(stdin|stdout|stderr)\\b" }
      ]
    },
    "types": {
      "name": "support.type.fc",
      "match": "\\b(i8|i16|i32|i64|u8|u16|u32|u64|isize|usize|f32|f64|bool|char|str|cstr|any|const)\\b"
    },
    "typevar": {
      "name": "variable.parameter.type.fc",
      "match": "'[A-Za-z]\\w*"
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.fc",
          "match": "\\b[0-9][0-9_]*(?:\\.[0-9][0-9_]*)?(?:[eE][-+]?[0-9]+)?(?:f32|f64)\\b"
        },
        {
          "name": "constant.numeric.float.fc",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*(?:[eE][-+]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.integer.fc",
          "match": "\\b0(?:[xX][0-9a-fA-F_]+|[bB][01_]+|[oO][0-7_]+)(?:[iu](?:8|16|32|64|size))?\\b"
        },
        {
          "name": "constant.numeric.integer.fc",
          "match": "\\b[0-9][0-9_]*(?:[iu](?:8|16|32|64|size))?\\b"
        }
      ]
    },
    "char": {
      "name": "string.quoted.single.fc",
      "match": "'(?:\\\\x[0-9a-fA-F]{2}|\\\\[ntr\\\\'\"0]|[^'\\\\])'"
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.fc",
          "begin": "c?\"",
          "end": "\"",
          "patterns": [
            { "include": "#escape" },
            { "include": "#interpolation" },
            { "name": "constant.character.escape.fc", "match": "%%" }
          ]
        }
      ]
    },
    "escape": {
      "name": "constant.character.escape.fc",
      "match": "\\\\(x[0-9a-fA-F]{2}|[ntr\\\\'\"0])"
    },
    "interpolation": {
      "name": "meta.interpolation.fc",
      "begin": "(%[-+ 0#]*[0-9]*(?:\\.[0-9]*)?[diuxXofeEgGscpT])(\\{)",
      "beginCaptures": {
        "1": { "name": "constant.character.format.fc" },
        "2": { "name": "punctuation.section.interpolation.begin.fc" }
      },
      "end": "\\}",
      "endCaptures": {
        "0": { "name": "punctuation.section.interpolation.end.fc" }
      },
      "patterns": [ { "include": "$self" } ]
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator.fc", "match": "->|::|\\.\\.|<<|>>|&&|\\|\\||==|!=|<=|>=" },
        { "name": "keyword.operator.fc", "match": "[-+*/%&|^~!<>=]" }
      ]
    }
  }
}
