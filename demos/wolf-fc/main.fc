// Wolfenstein FC — a Wolfenstein 3D engine written in FC using SDL2.
// Software-rendered raycaster with textured walls and procedural audio.

import sdl2 from sdl2::
import rect from sdl2::sdl2
import sdl_event from sdl2::sdl2
import audio_spec from sdl2::sdl2
import io from std::
import text from std::
import sys from std::
import math from std::

// ============================================================
// Constants
// ============================================================

let screen_w = 640
let screen_h = 400
let tex_size = 64
let tex_pixels = 4096
let fallback_map_size = 24
let move_speed = 0.05
let rot_speed = 0.035
let run_mult = 2.5

// ============================================================
// Types
// ============================================================

struct player =
    x: float64
    y: float64
    dir_x: float64
    dir_y: float64
    plane_x: float64
    plane_y: float64
    health: int32
    ammo: int32
    score: int32

struct input_state =
    move_fwd: bool
    move_back: bool
    turn_left: bool
    turn_right: bool
    run_held: bool
    fire_held: bool
    alt_held: bool

struct game_sprite =
    x: float64
    y: float64
    sprite_id: int32

struct world =
    p: player
    input: input_state
    map: int32[]
    map_w: int32
    map_h: int32
    sprites: game_sprite[]
    num_sprites: int32

// ============================================================
// Color helpers
// ============================================================

let clamp255 = (v: int32) ->
    if v < 0 then 0 else if v > 255 then 255 else v

let pack_argb = (r: int32, g: int32, b: int32) ->
    (255u32 << 24) | ((uint32) clamp255(r) << 16) | ((uint32) clamp255(g) << 8) | (uint32) clamp255(b)

let darken = (c: uint32) ->
    let r = (c >> 16) & 255u32
    let g = (c >> 8) & 255u32
    let b = c & 255u32
    (c & (255u32 << 24)) | ((r >> 1) << 16) | ((g >> 1) << 8) | (b >> 1)

// ============================================================
// Binary read helpers
// ============================================================

let read_u16 = (buf: uint8[], off: int32) ->
    (int32) buf[off] | ((int32) buf[off + 1] << 8)

let read_i32 = (buf: uint8[], off: int32) ->
    (int32) buf[off] | ((int32) buf[off + 1] << 8) | ((int32) buf[off + 2] << 16) | ((int32) buf[off + 3] << 24)

// ============================================================
// Wolf3D VGA palette (6-bit values, multiplied by 4 for 8-bit)
// ============================================================

let sp = (pal: uint32[], i: int32, r: int32, g: int32, b: int32) ->
    pal[i] = pack_argb(r * 4, g * 4, b * 4)
    return

let init_palette = () ->
    let pal = alloc(uint32[256] {})!
    sp(pal, 0, 0, 0, 0)
    sp(pal, 1, 0, 0, 42)
